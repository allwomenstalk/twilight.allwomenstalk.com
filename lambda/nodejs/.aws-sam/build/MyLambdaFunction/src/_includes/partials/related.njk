<p class="uppercase tracking-wide text-sm opacity-70 font-bold text-center mt-8">Related</p>

<div class="overflow-x-scroll mb-6 py-4 no-scrollbar max-w-2xl p-2 mx-auto" id="related">
  <div class="grid sm:grid-cols-2 gap-2">
    {% for post in post.related.posts %}
    <p alt="{{ post.title }}" class="items-center rounded overflow-hidden flex m-2 border bg-white dark:border-gray-700">
      <img src="{{ post.webp }}" style="width:3.5rem;height:3.5rem;background:#fff" alt="{{ post.title }}" loading="lazy">
      <a href="{{ post.url }}" class="_relatedsmall items-top px-2 text-sm h-12 overflow-hidden" style="padding-top:.25rem">{{ post.title }}</a>
    </p>
    {% endfor %}
  </div>
</div>
