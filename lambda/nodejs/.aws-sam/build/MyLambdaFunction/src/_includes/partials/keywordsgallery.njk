<div x-data="keywords" class="max-w-2xl mx-auto p-4">
  <h2 class="text-2xl font-bold tracking-tight text-gray-900">Trending searches</h2>
  <ul role="list" class="h-64 overflow-hidden mt-3 pt-2 grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6">
    <template x-for="item in keywords">
      <a :href="'https://allwomenstalk.com/gsearch/?q='+item.keyword" class="col-span-1 flex rounded-md shadow-sm">
        <div class="flex w-16 flex-shrink-0 items-center justify-center">
          <img x-bind:src="item.image" :alt="item.keyword" class="object-cover h-16 w-16 rounded-l-md">
        </div>
        <div class="flex flex-1 items-center justify-between truncate rounded-r-md border-b border-r border-t border-gray-200 bg-white">
          <div class="flex-1 truncate px-4 py-2 text-sm">
            <span x-text="item.keyword" class="font-medium capitalize text-gray-900 hover:text-gray-600"></span>
          </div>
          <div class="flex-shrink-0 pr-2">
            <svg class="_keywords w-6 pr-1 inline-block" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
            </svg>
          </div>
        </div>
        
      </a>
    </template>
  </ul>
</div>
