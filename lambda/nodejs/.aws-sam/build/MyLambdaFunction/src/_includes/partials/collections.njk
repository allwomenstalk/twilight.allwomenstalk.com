{% if post.collection %}
<nav class="m-4 mx-auto max-w-xl flex overflow-hidden"  aria-label="Breadcrumb">
  <ol role="list" class="flex items-center space-x-4 mx-4"> 
    <li>
      <div class="flex items-center">
        <a href="https://allwomenstalk.com/collections/" class="ml-4 text-sm font-medium hover:text-gray-700">Collection:</a>
      </div>
    </li>
    {% for collection in post.collection %}  
    <li>
      <div class="flex items-center">
        <!-- Heroicon name: mini/chevron-right -->
        <svg class="h-5 w-5 flex-shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
        </svg>
        <a href="https://allwomenstalk.com/c/{{collection.slug}}" class="ml-4 text-sm font-medium hover:text-gray-700">{{collection.name}}</a>
      </div>
    </li>
    {% endfor %}
  </ol>
</nav>
{% endif %}
