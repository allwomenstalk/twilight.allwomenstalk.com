      {% else %}
        {# <span class="slice" style="height: 257px;"></span> #}
      {% endif %}
    
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 p-4 max-w-screen-xl mx-auto">
    {% endif %}
  {% endif %}
{% endfor %}
</div>
