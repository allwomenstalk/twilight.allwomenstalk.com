---
layout: layout/default.njk
url: /login/
---

<main x-data="loginData()" class="mx-auto max-w-xl px-6 py-10">
  <h1 class="text-2xl font-bold">Supabase Login (Dev)</h1>
  <p class="mt-2 text-sm text-gray-600">Use email OTP to sign in on localhost.</p>

  <div class="mt-6 grid gap-3">
    <input x-model="email" type="email" placeholder="Email" class="block w-full rounded-md border-gray-300 px-3 py-2 text-sm" />
    <input x-show="codeSent" x-model="otp" type="text" inputmode="numeric" maxlength="6" placeholder="6-digit OTP" class="block w-full rounded-md border-gray-300 px-3 py-2 text-sm" />
    <div class="flex gap-2">
      <button
        x-show="!codeSent"
        @click="sendOtp"
        class="rounded-md bg-pink-600 px-3 py-2 text-sm font-semibold text-white"
      >Send OTP</button>
      <button
        x-show="codeSent"
        @click="verifyOtp"
        :disabled="otp.trim().length < 6"
        :class="{ 'opacity-60 cursor-not-allowed': otp.trim().length < 6 }"
        class="rounded-md bg-pink-600 px-3 py-2 text-sm font-semibold text-white"
      >Log in</button>
      <button
        x-show="codeSent"
        @click="sendOtp"
        class="rounded-md bg-pink-100 px-3 py-2 text-sm font-semibold text-pink-700"
      >Resend code</button>
      <button @click="logout" class="rounded-md bg-gray-200 px-3 py-2 text-sm font-semibold text-gray-900">Logout</button>
    </div>
  </div>

  <template x-if="user">
    <div class="mt-6 rounded-md border border-green-200 bg-green-50 p-3 text-sm">
      Logged in as: <strong x-text="user.email"></strong>
    </div>
  </template>

  <template x-if="message">
    <p class="mt-3 text-sm" x-text="message"></p>
  </template>
</main>

<script src="//unpkg.com/alpinejs" defer></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
const SUPABASE_URL = 'https://olgdvvxouytdchveiaad.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9sZ2R2dnhvdXl0ZGNodmVpYWFkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTE5MDA1OTEsImV4cCI6MjA2NzQ3NjU5MX0.Y8QlgS1L8oaxdNuRWtAF2QnCewXUE0dS91MSt_BtU_8';

function loginData() {
  return {
    email: '',
    otp: '',
    codeSent: false,
    user: null,
    message: '',
    supabase: null,

    async init() {
      this.supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
        auth: {
          persistSession: true,
          autoRefreshToken: true,
          detectSessionInUrl: true,
        },
      });
      const { data } = await this.supabase.auth.getUser();
      this.user = data?.user || null;
      this.supabase.auth.onAuthStateChange((_event, session) => {
        this.user = session?.user || null;
      });
    },

    async sendOtp() {
      this.message = '';
      const { error } = await this.supabase.auth.signInWithOtp({
        email: this.email,
        options: {
          shouldCreateUser: false,
        },
      });
      if (error) {
        this.message = error.message;
        return;
      }
      this.codeSent = true;
      this.message = 'OTP sent. Check your email.';
    },

    async verifyOtp() {
      this.message = '';
      const token = (this.otp || '').trim();
      if (!this.email || token.length < 6) {
        this.message = 'Enter email and 6-digit OTP.';
        return;
      }
      const { error } = await this.supabase.auth.verifyOtp({
        email: this.email,
        token,
        type: 'email',
      });
      if (error) {
        this.message = error.message;
        return;
      }
      this.codeSent = false;
      this.otp = '';
      this.message = 'Login successful';
    },

    async logout() {
      this.message = '';
      await this.supabase.auth.signOut();
      this.codeSent = false;
      this.otp = '';
      this.message = 'Logged out';
    },
  };
}
</script>
