---
layout: layout/archive.njk
permalink: /allwomenstalk.com/discussion/index.html
eleventyComputed:
  title: Discussion - Allwomenstalk
  url: "{{ metadata.host }}/discussion/"
---
<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-base/7 font-semibold text-pink-600">Message Board</h2>
      <p class="mt-2 text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Recent comments from the community</p>
      <p class="mt-4 text-sm text-gray-500">Latest comments</p>
    </div>

    {% if comments and comments.length > 0 %}
      <div class="mx-auto mt-16 flow-root max-w-2xl sm:mt-20 lg:mx-0 lg:max-w-none">
        <div class="-mt-8 sm:-mx-4 sm:columns-2 sm:text-[0] lg:columns-3">
          {% for item in comments %}
            <div class="pt-8 sm:inline-block sm:w-full sm:px-4">
              <figure class="rounded-2xl bg-gray-50 p-8 text-sm/6 ring-1 ring-gray-200 transition hover:bg-white hover:ring-pink-200">
                <blockquote class="text-gray-900">
                  <p>{{ item.excerpt }}</p>
                </blockquote>
                <figcaption class="mt-6">
                  <div>
                    <div class="text-xs font-semibold text-gray-900">{{ item.author }}</div>
                    {% if item.post.url %}
                      <a href="{{ item.post.url }}" class="block max-w-full truncate text-xs text-gray-600 hover:text-pink-600">
                        {{ item.post.title }}
                      </a>
                    {% else %}
                      <div class="text-xs text-gray-400">Post link unavailable</div>
                    {% endif %}
                    <div class="mt-1 inline-flex items-center gap-1 text-xs text-pink-600">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-4">
                        <path d="M1 8.74c0 .983.713 1.825 1.69 1.943.904.108 1.817.19 2.737.243.363.02.688.231.85.556l1.052 2.103a.75.75 0 0 0 1.342 0l1.052-2.103c.162-.325.487-.535.85-.556.92-.053 1.833-.134 2.738-.243.976-.118 1.689-.96 1.689-1.942V4.259c0-.982-.713-1.824-1.69-1.942a44.45 44.45 0 0 0-10.62 0C1.712 2.435 1 3.277 1 4.26v4.482Z" />
                      </svg>
                      <span>{{ item.post.commentCount or 0 }}</span>
                    </div>
                  </div>
                </figcaption>
              </figure>
            </div>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="mx-auto mt-16 max-w-2xl rounded-2xl border border-dashed border-gray-300 p-10 text-center text-sm text-gray-500">
        No comments found yet.
      </div>
    {% endif %}
  </div>
</div>
