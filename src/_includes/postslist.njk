{% if loopNumber % 7 == 0 %}
{% set bigcard = true %}
{% endif %}
{% set badge_colors = [
  "bg-rose-50 text-rose-700 ring-rose-200",
  "bg-amber-50 text-amber-700 ring-amber-200",
  "bg-emerald-50 text-emerald-700 ring-emerald-200",
  "bg-sky-50 text-sky-700 ring-sky-200",
  "bg-violet-50 text-violet-700 ring-violet-200",
  "bg-fuchsia-50 text-fuchsia-700 ring-fuchsia-200",
  "bg-orange-50 text-orange-700 ring-orange-200",
  "bg-lime-50 text-lime-700 ring-lime-200"
] %}
{% set badge_color = badge_colors[((loopNumber or 1) - 1) % (badge_colors | length)] %}

<a href="{{post.url}}"  
  class="text-gray-900 rounded-2xl hover:opacity-70 {% if bigcard %}col-span-full md:flex {% endif %} relative" 
  title="{{post.keyword or post.title}}">
      <div class="{% if bigcard %}md:w-1/2 md:h-96 md:rounded-tl-2xl md:rounded-bl-2xl md:rounded-tr-none md:rounded-br-none {% endif %}
                  text-center overflow-hidden bg-cover bg-center rounded-t-2xl">
        <img class="w-full "
        {% if bigcard %}
          width="800" height="800"
          src="{{ post.image }}"
          data-srcset="{{post.imageresize}}?width=400&height=400 500w, 
            {{post.imageresize}}?width=800&height=800 1000w, 
            {{post.imageresize}}?width=1200&height=1200  1500w"
        {% else %}
          width="200" height="200"
          src="{{post.imageresize}}?width=400&height=400"
        {% endif %}
            alt="{{ post.title }}" 
            loading="lazy" 
            decoding="async"/>
      </div>
      <div class="{% if bigcard %}md:w-1/2 md:h-96 md:rounded-l-none md:rounded-r-2xl md:border-t md:border-l-0{% endif %}
                   border-r border-b border-l  border-gray-300 rounded-b-2xl  p-4 flex flex-col justify-between leading-normal h-56 cardtitle bg-white dark:bg-gray-900">
        <div>
          <p class="inline-flex items-center rounded-full px-1.5 py-0.5 text-[8px] font-medium uppercase ring-1 ring-inset {{ badge_color }}">
              {{ post.tags }} 
              {%- for e in categories -%}
              {%- if e.name == post.tags -%}{{ e.icon }}{%- endif -%}
              {%- endfor -%}
          </p>
          {# {% set emoji = ['🎄','🎅', '❄️', '🎉'] | shuffle %} #}
          <h2 class="my-2 font-display {% if bigcard %}text-base capitalize font-bold md:text-3xl lg:text-5xl{% else %}text-sm{% endif %}">
            {{ post.title }} 
          </h2>
          {# <p class="text-gray-700 text-base">{{ emoji[0] }}</p> #}
        </div>
        {% if bigcard or post.stats.clicks or not bigcard %}
          <div class="flex items-end justify-between gap-3">
            <div class="text-xs opacity-70">
              {% if bigcard or post.stats.clicks %}
                {% if metadata.NODE_ENV != "production" %}
                <p class="leading-none">{{ post.fulldate }}</p>
                <p class="leading-none">{{ post.post_date }}</p>
                <p class="leading-none">{{ post.seo.clicks }} clk</p>
                <p class="leading-none">{{ post.seo.impressions }} imp</p>
                <p class="leading-none">{{ post.seo.keywords }} kws</p>
                <p class="leading-none">{{ post.author.name }}</p>
                <p class="leading-none">{{ post.parent.title }}</p>
                {% endif %}
                {% if post.stats.clicks %}
                <p class="leading-none">{{ post.stats.clicks }} likes</p>
                {% else %}
                <p class="leading-none">{{ post.date }}</p>
                {% endif %}
              {% endif %}
            </div>
            {% if bigcard %}
              <span class="inline-flex items-center text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                </svg>
              </span>
            {% endif %}
          </div>
          {% if not bigcard %}
            <div class="mt-3 flex justify-end">
              <span class="inline-flex items-center text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                </svg>
              </span>
            </div>
          {% endif %}
        {% endif %}
      </div>
</a>
