<!doctype html>
<html lang="en">
<head data-postid="{{ post.id }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5">
    <title>{{ post.title }}</title>
    <meta name="author" content="{{ post.author }}">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ post.title }}">
    <meta property="og:description" content="{{ post.description }}">
    <meta property="og:url" content="{{ post.url }}">
    <meta property="og:site_name" content="{{ post.site_name }}">
    <meta property="og:image" content="{{ post.image }}">
    <meta property="article:published_time" content="{{ post.published_time }}">
    <meta property="article:author" content="{{ post.author }}">
    <meta name="apple-itunes-app" content="{{ post.itunes_app }}">
    <meta name="robots" content="{{ post.robots }}">
    <meta name="generator" content="{{ post.generator }}">
    <meta name="description" content="{{ post.description }}">
    <link rel="canonical" href="{{ post.canonical_url }}">
    <link rel="amphtml" href="{{ post.amp_url }}">
    {# <script src="https://cdn.tailwindcss.com"></script> #}
    {# add alpine #}
    {# <script src="https://account.allwomenstalk.com/js/cookiecross.js" defer></script> #}
    {# <script src="https://account.allwomenstalk.com/js/profile.js" defer></script> #}

    {# <script src="https://unpkg.com/realm-web/dist/bundle.iife.js" defer></script> #}
    {# <script src="/assets/js/azo.js" defer></script> #}
   
    {% if metadata.NODE_ENV == "production" %}
            {% set css %}
            {% include 'partials/css/base.css' %}
            {% endset %}
            <style>
            {{ css  | safe }}
            </style>
    {% else %}
        <link rel="stylesheet" href="/base.css">
    {% endif %}
    

        {% if metadata.NODE_ENV == "production" %}
            {% set css %}
            {% include 'partials/css/site.css' %}
            {% endset %}
            <style>
            {{ css  | safe }}
            </style>
    {% else %}
        <link rel="stylesheet" href="/site.css">
    {% endif %}
    <style>[x-cloak] { display: none !important; }</style>
</head> 

<body x-data="data()" @scroll.window.throttle="check"  class="dark:bg-gray-900 dark:text-white relative">
    
    {% include 'partials/navigation.njk' %}
    {% include 'partials/search.njk' %}
    {{ content | safe }}



    {% include "partials/footer.njk" %}

    {% include "partials/jsinline.njk" %}

</body>

</html>


<style>

    {# animation for loading  #}
#leaderboard {
    background-image: url(data:image/svg+xml;base64,);
    background-repeat: no-repeat;
    background-position: center;
    background-size:50px
}

.flag::after {
    content: 'Report'
}
</style>
