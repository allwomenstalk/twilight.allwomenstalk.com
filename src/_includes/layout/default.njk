<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5">
    <title>{{ post.title | default(title) }}</title>
    <meta property="og:title" content="{{ post.viral or post.title or title }}">
    <meta property="og:description" content="{{ post.description | default(description) }}">
    <meta property="og:url" content="{{ post.url | default (url) }}">
    <meta property="og:site_name" content="{{ post.site_name | default(metadata.title) }}">
    <meta name="description" content="{{ post.description | default(metadata.description) }}">
    <link rel="canonical" href="{{ post.url | default(url) }}">
    {# favicon #}
    <link rel="icon" href="https://pub-56c58d9f0cd64f4ea0f67eba69a26e7b.r2.dev/favicon.ico" type="image/x-icon">

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <meta name="generator" content="{{ metadata.generator }}">
    {% if post %}
    <meta name="postid" content="{{ post.id }}">
    {% endif %}
    
    {% if post %}
    {% include 'partials/postmeta.njk' %}
    {% endif %}

    {# <script src="https://cdn.tailwindcss.com"></script> #}
    {# add alpine #}
    {# <script src="https://account.allwomenstalk.com/js/cookiecross.js" defer></script> #}
    {# <script src="https://account.allwomenstalk.com/js/profile.js" defer></script> #}
    {# <script src="https://unpkg.com/realm-web/dist/bundle.iife.js" defer></script> #}
    {# <script src="/assets/js/azo.js" defer></script> #}
   
    {% if metadata.NODE_ENV == "production" %}
            {% set css %}
            {% include 'partials/css/base.css' %}
            {% endset %}
            <style>
            {{ css  | safe }}
            </style>
    {% else %}
        <link rel="stylesheet" href="/base.css">
    {% endif %}

    <style>[x-cloak] { display: none !important; }</style>




<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-5NR9WTN');</script>
<!-- End Google Tag Manager -->

</head> 

<body x-data="data()" 
      @scroll.window.throttle="check"  
      @keydown.cmd.k="showsearch()"  
      class="bg-gray-50 relative">
    
    {% include 'partials/navigation.njk' %}
    {% include 'partials/search.njk' %}
    {{ content | safe }}



    {% include "partials/footer.njk" %}
    <!-- js.njk -->
    {% include "partials/js.njk" %}

    {% if metadata.NODE_ENV == "production" %}
            {% set css %}
            {% include 'partials/css/site.css' %}
            {% endset %}
            <style>
            {{ css  | safe }}
            </style>
    {% else %}
        <link rel="stylesheet" href="/site.css">
    {% endif %}

<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5NR9WTN"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<style>

    {# animation for loading  #}
#leaderboard {
    background-image: url(data:image/svg+xml;base64,);
    background-repeat: no-repeat;
    background-position: center;
    background-size:50px
}

.flag::after {
    content: 'Report'
}
</style>


</body>

</html>



