  <div class="bg-white" x-data="productList()">
        <div class="py-16 sm:py-24 lg:mx-auto lg:max-w-7xl lg:px-8">
            <div class="flex items-center justify-center px-4 sm:px-6 lg:px-0">
                <h2 class="text-2xl font-bold tracking-tight text-gray-900">Trending products</h2>
            </div>
            <div class="relative mt-8">
                <div class="relative -mb-6 w-full overflow-x-auto pb-6">
                    <ul role="list" class="mx-4 inline-flex space-x-8 sm:mx-6">
                        <template x-for="product in products" :key="product.URL">
                            <a :href="product.link" target="_blank" class="inline-flex w-40 flex-col text-center">
                                <div class="group relative">
                                    <button @click="select(product)">
                                        <img :src="product.Image" alt="" class="aspect-square w-full rounded-md bg-gray-200 object-cover group-hover:opacity-75">
                                    </button>
                                    <div class="mt-6">
                                        <h3 class="mt-1 font-semibold text-gray-900 whitespace-nowrap overflow-hidden overflow-ellipsis">
                                            <button @click="select(product)">
                                                <span class="absolute inset-0"></span>
                                                <span x-text="product.Title"></span>
                                            </button>
                                        </h3>
                                        <p class="mt-1 text-gray-900" x-text="product.MSRP"></p>
                                    </div>
                                </div>
                            </a>
                        </template>
                    </ul>
                </div>
            </div>
            <div class="mt-12 flex px-4 sm:hidden">
                <a href="#" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500">
                    See everything 
                    <span aria-hidden="true">&rarr;</span>
                </a>
            </div>
        </div>
    </div>
    <script>
    function productList() {
        return {
            products: [],
            hasFetched: false,

            init() {
                const observer = new IntersectionObserver((entries, observer) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting && !this.hasFetched) {
                            this.hasFetched = true;
                            this.fetchProducts();
                            observer.unobserve(entry.target); // Unobserve after first fetch
                        }
                    });
                });

                requestAnimationFrame(() => {
                    observer.observe(this.$el);
                });
            },

            fetchProducts() {
                const categoryUrl = `https://pub-32f53c81c4ca4d1b9c8f46637cea8290.r2.dev/feed/{{post.category}}.json`;
                const defaultUrl = 'https://pub-32f53c81c4ca4d1b9c8f46637cea8290.r2.dev/feed/default.json';

                console.log(`Trying to fetch: ${categoryUrl}`);
                feed = "{{post.category}}"
                fetch(categoryUrl)
                .then(response => {
                    if (!response.ok) {
                        console.warn(`Category fetch failed (${response.status}), trying default...`);
                        feed = "default"
                        return fetch(defaultUrl);
                    }
                    return response;
                })
                .then(response => response.json())
                .then(data => {
                    console.log('Products data loaded:', data);
                    data.forEach((product, index) => {
                        product.link = 'https://allwomenstalk.com/products/?id='+feed+'-'+index;

                    });
                    this.products = data.sort(() => Math.random() - 0.5);
                })
                .catch(error => {
                    console.error('Final fetch error:', error);
                });
            },

            async select(item) {
                console.log(item);
                try {
                    const response = await fetch('https://botnotify.iniret.workers.dev/', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            title: item.Title,
                            price: item.MSRP
                        })
                    });

                    const result = await response.json();
                    console.log('Success:', result);
                } catch (error) {
                    console.error('Error sending product:', error);
                }

                // open url 
            }
        }
    }
    </script>