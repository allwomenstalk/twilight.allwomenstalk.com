<div class="hero mb-6 overflow-hidden">
  <div class="text-center  mt-0 p-6 align-middle relative bg-gradient-to-r to-80% from-pink-600 to-pink-800 text-gray-100">
    <div class="uppercase tracking-wide text-sm font-bold text-white opacity-70">
      <a href="https://{{ post.category[0] }}.allwomenstalk.com/" class="">{{ post.category[0] }}</a>
      •
      <a href="#rating" class="">{{ post.ratingstars }}</a>
    </div>
    <h1 class=" mx-auto  text-4xl md:text-6xl 2xl:text-9xl p-8 md:p-16 xl:p-32 overflow-hidden">{{ post.title }}</h1>
    <p class="mt-2 text-sm text-white opacity-70 ">
      By
      <a href="https://allwomenstalk.com/profile/{{ post.author.id }}/" class="text-white">{{ post.author.name }}</a>

      {# comments button or comments link #}
      {% if (post.comment_count > 1) %}
      
          {% if amp %}
          • <a href="{{post.url}}#comments" class=" px-2.5 py-1.5 text-sm font-semibold text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
            {{ post.comment_count }} Comments
          </a>
          {% else %}
          • <button @click="commentspanel=true;getComments()" type="button" class=" px-2.5 py-1.5 text-sm font-semibold text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
            {{ post.comment_count }} Comments
          </button>
          {% endif %}

      {% endif %}

      {# native share #}
      {% if amp %}
      {# <amp-social-share type="system" aria-label="Share">Share</amp-social-share> #}
      {% else %}
      • <button @click="share()" type="button" class=" px-2.5 py-1.5 text-sm font-semibold text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
        <svg class="w-5 inline-block " fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"></path>
        </svg> 
        <span class="hidden md:inline-block">Share</span>
      </button>
      {% endif %}


    </p>
    <svg class="text-pink-800 z-10 hidden md:block absolute right-0 inset-y-0 h-full w-48 transform translate-x-1/2 " fill="currentColor" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
      <polygon points="50,0 100,0 50,100 0,100"></polygon>
    </svg>
  </div>


  <div class="relative bg-black border-red-500 max-w-2xl mx-auto md:my-2 md:rounded-md overflow-hidden">
    
    {% if post.image %}
    <img class="object-cover w-full h-full " id="coverimage" src="{{ post.image }}" alt="{{ post.title }}" width="{{ post.imagesize.width }}" height="{{ post.imagesize.height }}" 
    srcset="{{ post.imagewebp400 }} 400w, 
            {{ post.imagewebp800 }} 800w, 
            {{ post.imagewebp1200 }} 1200w, 
            {{ post.image }} 1x" decoding="async">

    <button x-cloak x-show="source" @click="window.open(source.source_url, '_blank')" class="absolute text-black text-2xl bottom-2 right-2 z-20 opacity-70 hover:opacity-100">
      <span x-text="source.source_name" class="inline-flex items-center rounded-md bg-white px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10"></span>
    </button>

    {# <picture class="object-cover h-48 w-96" id="coverimage" alt="{{ post.title }}" width="{{ post.imagesize.width }}" height="{{ post.imagesize.height }}" >
      <source type="image/webp" srcset="{{ post.imagewebp1200 }}" media="(max-width: 1200px)">
      <source type="image/webp" srcset="{{ post.imagewebp800 }} 1x, {{ post.imagewebp1200 }} 2x" media="(max-width: 800px)">
      <source type="image/webp" srcset="{{ post.imagewebp400 }} 1x, {{ post.imagewebp800 }} 2x" media="(max-width: 400px)">
      <source type="image/jpeg" srcset="{{ post.imageresize }} 1x" media="(max-width: 1200px)">
      <img src="{{ post.image }}" alt="" decoding="async" width="{{ post.imagesize.width }}" height="{{ post.imagesize.height }}">
    </picture> #}
  
    {% endif %}

  </div>
</div>
