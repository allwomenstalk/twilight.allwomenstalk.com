<div x-data="{ 
    show: true,
    trackAndOpen() {
        beacontrack({ type: 'preferred', post_id: '{{post.id}}', action: 'click' });
        window.open('https://www.google.com/preferences/source?q=allwomenstalk.com', '_blank', 'noopener,noreferrer');
    }
}" x-show="show" class="relative bg-white border border-gray-200 rounded-lg shadow-sm p-4 mb-4 max-w-xl mx-auto">
    <div class="flex items-center gap-4">
        <button @click="trackAndOpen()" class="flex-shrink-0 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded cursor-pointer" aria-label="Subscribe to Google Preferred Source">
            <img
                alt="Google Preferred Source Banner"
                loading="lazy"
                width="200"
                height="63"
                decoding="async"
                class="w-auto h-16"
                src="https://allwomenstalk.github.io/images/google-preferred-source-badge.webp">
        </button>
        <span class="flex-1 text-sm pr-4 text-gray-700">
            Add allwomenstalk.com as a preferred source on Google to see more of our trusted coverage when you search.
        </span>
    </div>
    <button @click="show = false; beacontrack({ type: 'preferred', post_id: '{{post.id}}', action: 'dismiss' })" class="absolute top-2 right-2 p-2 hover:bg-gray-100 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-gray-300" aria-label="Dismiss banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" focusable="false" class="w-4 h-4">
            <g>
                <path d="M15 1L1 15" stroke="currentColor" stroke-width="0.777778" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M1 1L15 15" stroke="currentColor" stroke-width="0.777778" stroke-linecap="round" stroke-linejoin="round"></path>
            </g>
        </svg>
    </button>
</div>