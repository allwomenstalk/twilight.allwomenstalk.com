{% if inline %}
<div class="max-w-2xl mx-auto px-2 sm:px-8">
  <div class="flex w-ful sm:max-w-xs  border-gray-300 dark:border-gray-700 rounded-md  m-2">
      <img src="{{ inline.webp }}" class="h-12 w-12 rounded-full border-2 border-white ring-2 ring-pink-500 flex-shrink-0 object-cover" alt="{{ inline.title }}" loading="lazy"/>
      <div class="flex flex-col justify-center ml-2 overflow-ellipsis overflow-hidden">
          <span class="font-semibold text-xs opacity-70">Related:</span>
          <a href="{{ inline.url }}" class="text-sm text-pink-600 truncate "> {{ inline.title }} </a>
      </div>
  </div>
</div>
{% endif %}
