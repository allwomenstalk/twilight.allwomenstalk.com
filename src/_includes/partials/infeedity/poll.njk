    "options": ["Morning", "Night", "Both", "Neither"]
  }
]

  const shuffleArray = (array) => {
    for (let i = array.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [array[i], array[j]] = [array[j], array[i]];
    }
    return array;
  };

  const getAnsweredQuestions = () => {
    const answered = localStorage.getItem('answeredPolls');
    return answered ? JSON.parse(answered) : [];
  };

  const saveAnsweredQuestion = (question) => {
    const answered = getAnsweredQuestions();
    if (!answered.includes(question)) {
      answered.push(question);
      localStorage.setItem('answeredPolls', JSON.stringify(answered));
    }
  };

  const getUnansweredQuestions = () => {
    const answered = getAnsweredQuestions();
    return pollsData.filter((poll) => !answered.includes(poll.question));
  };

  const shuffledPolls = shuffleArray(getUnansweredQuestions());

  return {
    polls: shuffledPolls,
    currentIndex: 0,
    selectedOption: null,
    completed: false,
    disabled: false,

    init() {
      this.polls = shuffledPolls.slice(0, 5);
    },

    get currentQuestion() {
      return this.polls[this.currentIndex]?.question || "No more questions!";
    },

    get currentOptions() {
      return this.polls[this.currentIndex]?.options || [];
    },

    selectOption(option) {
      this.selectedOption = option;
      const currentQuestion = this.polls[this.currentIndex]?.question;
      saveAnsweredQuestion(currentQuestion);

      if (this.completed) {
        this.onComplete();
      }

      // Add delay for smooth transition
      this.disabled = true;
      setTimeout(() => {
        this.nextQuestion();
      }, 1500);
    },

    nextQuestion() {
      if (this.currentIndex < this.polls.length - 1) {
        this.currentIndex++;
        this.selectedOption = null;
        this.disabled = false;
      } else {
        this.onComplete();
      }
    },

    onComplete() {
      context.showPoll = false;
      if (this.completed) {
        context.currentTitle = this.completed;
      }
    }
  };
}

