<div x-data="poll" x-ref="pollblock" class="mx-auto max-w-xl py-3 px-4 md:px-0">
  <template x-for="(item,i) in poll">
  <div x-show="index==i" x-transition.300 class="w-full">
    <div class="py-2">
      <h4 class="text-xs font-semibold uppercase tracking-wide text-pink-600">Reader Poll</h4>
      <question x-html="item.question" class="mt-1 block text-lg font-semibold leading-7 text-gray-900 sm:text-xl"></question>
      <div class="mt-3 flex flex-wrap gap-2">
        <template x-for = "(option, x) in item.options">
        <button
          x-show="buttons"
          @click="select(item.question,option)"
          x-transition.300
          x-text="option"
          :class="getPillClass(item.question, option)"
          class="inline-flex max-w-full items-center rounded-full px-2 py-1 text-left text-xs font-medium ring-1 ring-inset whitespace-normal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-500"
        >{{option}}</button>
        </template>
      </div>
    </div>
  </div>
  </template>

  {# <div x-show="index>0&&index==poll.length" x-cloak class="mx-auto  py-16 ">
