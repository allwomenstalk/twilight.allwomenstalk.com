    <div class="p-4 sm:p-0">
      <h4 class="text-base font-semibold leading-7 text-pink-600">Snapshot Survey</h4>
      <question x-html="item.question" class="text-2xl font-bold tracking-tight  sm:text-4xl"></question>
      <div class="grid grid-cols-2 gap-4 mt-5 items-center">
        <template x-for = "(option, x) in item.options">
        <button x-show="buttons" @click="select(item.question,option)" x-transition.300 x-text="option" class="rounded-md bg-pink-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">{{option}}</button>
        </template>
      </div>
    </div>
  </div>
  </template>

