</div>

<script>
    function poll() {
        return {
      // random number between 0 and and poll length
      index: 0,
      email: "",
      choices: [],
      poll: [],
      buttons: true,
      message: "",
      subscribed: false,
      category: "{{post.category}}", 
      postId: "{{post.id}}",
      init() {
          console.log('init poll')
          
          // Get category from URL or use 'general' as fallback
          const urlParams = new URLSearchParams(window.location.search);
          const category = this.category;
          
          // Construct R2 URL
          const baseUrl = 'https://pub-6552e6724af743cb85ba134221b75702.r2.dev';
          const pollUrl = `${baseUrl}/${category}.json`;
          
          console.log('Fetching polls from:', pollUrl);
          
          fetch(pollUrl)
          .then(response => {
            if (!response.ok) {
              console.log(`Failed to load ${category}.json, falling back to general.json`);
              // Fallback to general.json if category fails
              return fetch(`${baseUrl}/general.json`);
            }
            return response;
          })
          .then(response => response.json())
          .then(data => {
            console.log(data)
              this.poll = data
              // shuffle the poll
              console.log('data init')
              this.poll = this.poll.sort(() => Math.random() - 0.5)

              
              // get randob lengths subarray but no less than 3
              this.poll = this.poll.slice(0,3)
          })
          .catch(error => {
            console.error('Error loading polls:', error);
            // Final fallback to general.json
            fetch(`${baseUrl}/general.json`)
              .then(response => response.json())
              .then(data => {
                console.log('Loaded fallback general.json', data);
                this.poll = data;
                this.poll = this.poll.sort(() => Math.random() - 0.5);
                this.poll = this.poll.slice(0,3);
              })
              .catch(err => console.error('Failed to load fallback:', err));
          })

          {# 
          this.observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                      console.log("On!")
                      this.typein()            
                    }
                });
            });

            this.observer.observe(this.$refs.pollblock); 
            #}
      },
      typein() {
          typeWriter(this.poll[0].question, 100, 
              (text) => { // Update callback
                  this.poll[0].question = text;
              },
              () => { // Completion callback
                  this.buttons = true
              }
          );
      },
      select(q,choice) {
        console.log(q, choice)
        this.choices.push({q,choice})
        this.vote({
          q: q,
          a: choice,
          index: this.index
        })
        this.index++
      },
      vote (obj) {
          console.log(obj)
          this.trackEvent(obj.q, obj.a)
      },
      sub() {
        console.log(this.choices, this.email)
        const url = 'https://olgdvvxouytdchveiaad.supabase.co/functions/v1/subscribe';
        const payload = { 
          params: this.choices, 
          email: this.email
        };

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Network response was not ok');
          }
          return response.json();
        })
        .then(data => {
          console.log(data);
          this.subscribed = true;
        })
        .catch(error => {
          console.error('There was a problem with the fetch operation:', error);
          this.message = 'Oops! Something went wrong. Please try again.';
        });

      },
        async trackEvent(question, answer) {
            const obj = {
                type : 'poll',
                action: 1,
                post_id: this.postId,
                item: {
                    question: question,
                    answer: answer, 
                }
            }
            beacontrack(obj)        
        },
      }
    }

    function splitText(text) {
        const words = text.split(' ');
        const halfIndex = Math.floor(words.length / 2);
        return [words.slice(0, halfIndex).join(' '), words.slice(halfIndex).join(' ')];
    }

{# function typeWriter(text, speed, updateCallback, completionCallback) {
    let i = 0;
    let currentText = '';

    function typing() {
        if (i < text.length) {
            currentText = text.substring(0, i + 1) + '_'; // Append underscore during typing
            updateCallback(currentText);
            i++;
            setTimeout(typing, speed);
        } else {
            updateCallback(text); // Update final text without underscore
            if (completionCallback) completionCallback(); // Call completion callback
        }
    }

    typing();
} #}
</script>