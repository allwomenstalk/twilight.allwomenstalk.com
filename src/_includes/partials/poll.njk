  <div x-show="index>0&&index==poll.length" x-cloak class="mx-auto py-4">
    <div class="mx-auto max-w-xl">
      <div x-show="!subscribed" x-transition.300>
        <div class="max-w-xl text-gray-900">
          <p class="text-base font-semibold">Thanks for sharing your thoughts.</p>
          <p class="text-sm text-gray-700">Want more like this? Subscribe for personalized picks.</p>
        </div>
        <form class="mt-2 max-w-xl" @submit.prevent="sub()">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <label for="email-address" class="sr-only">Email address</label>
            <input id="email-address" x-model="email" name="email" type="email" autocomplete="email" required class="min-w-0 flex-auto rounded border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 focus:border-pink-500 focus:outline-none" placeholder="Email address">
            <button type="submit" class="inline-flex items-center justify-center rounded bg-pink-600 px-3 py-2 text-sm font-semibold text-white hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">Subscribe</button>
          </div>
        </form>
      </div>
      
      <div x-show="subscribed" x-transition.300 class="max-w-xl text-gray-900">
        <p class="text-base font-semibold">Successfully subscribed.</p>
        <p class="text-sm text-gray-700">Check your inbox for personalized content.</p>
      </div>
    </div>
  </div>
  

</div>

<script>
    function poll() {
        return {
      // random number between 0 and and poll length
      index: 0,
      email: "",
      choices: [],
      poll: [],
      buttons: true,
      message: "",
      subscribed: false,
      optionPillClasses: {},
      pillColorClasses: [
        'bg-gray-50 text-gray-600 ring-gray-500/10 dark:bg-gray-400/10 dark:text-gray-400 dark:ring-gray-400/20',
        'bg-red-50 text-red-700 ring-red-600/10 dark:bg-red-400/10 dark:text-red-400 dark:ring-red-400/20',
        'bg-yellow-50 text-yellow-800 ring-yellow-600/20 dark:bg-yellow-400/10 dark:text-yellow-500 dark:ring-yellow-400/20',
        'bg-green-50 text-green-700 ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:ring-green-500/20',
        'bg-blue-50 text-blue-700 ring-blue-700/10 dark:bg-blue-400/10 dark:text-blue-400 dark:ring-blue-400/30',
        'bg-indigo-50 text-indigo-700 ring-indigo-700/10 dark:bg-indigo-400/10 dark:text-indigo-400 dark:ring-indigo-400/30',
        'bg-purple-50 text-purple-700 ring-purple-700/10 dark:bg-purple-400/10 dark:text-purple-400 dark:ring-purple-400/30',
        'bg-pink-50 text-pink-700 ring-pink-700/10 dark:bg-pink-400/10 dark:text-pink-400 dark:ring-pink-400/20'
      ],
      category: "{{post.category}}", 
      postId: "{{post.id}}",
      init() {
          console.log('init poll')
          
          // Get category from URL or use 'general' as fallback
          const urlParams = new URLSearchParams(window.location.search);
          const category = this.category;
          
          // Construct R2 URL
          const baseUrl = 'https://pub-6552e6724af743cb85ba134221b75702.r2.dev';
          const pollUrl = `${baseUrl}/${category}.json`;
          
          console.log('Fetching polls from:', pollUrl);
          
          fetch(pollUrl)
          .then(response => {
            if (!response.ok) {
              console.log(`Failed to load ${category}.json, falling back to general.json`);
              // Fallback to general.json if category fails
              return fetch(`${baseUrl}/general.json`);
            }
            return response;
          })
          .then(response => response.json())
          .then(data => {
            console.log(data)
              this.poll = data
              // shuffle the poll
              console.log('data init')
              this.poll = this.poll.sort(() => Math.random() - 0.5)

              
              // get randob lengths subarray but no less than 3
              this.poll = this.poll.slice(0,3)
              this.assignPillColors()
          })
          .catch(error => {
            console.error('Error loading polls:', error);
            // Final fallback to general.json
            fetch(`${baseUrl}/general.json`)
              .then(response => response.json())
              .then(data => {
                console.log('Loaded fallback general.json', data);
                this.poll = data;
                this.poll = this.poll.sort(() => Math.random() - 0.5);
                this.poll = this.poll.slice(0,3);
                this.assignPillColors();
              })
              .catch(err => console.error('Failed to load fallback:', err));
          })

          {# 
          this.observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                      console.log("On!")
                      this.typein()            
                    }
                });
            });

            this.observer.observe(this.$refs.pollblock); 
            #}
      },
      assignPillColors() {
        const classes = {};
        const shuffle = (arr) => {
          const copy = [...arr];
          for (let i = copy.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [copy[i], copy[j]] = [copy[j], copy[i]];
          }
          return copy;
        };

        let queue = shuffle(this.pillColorClasses);
        let lastColor = null;

        const nextColor = () => {
          if (queue.length === 0) {
            queue = shuffle(this.pillColorClasses);
            if (queue.length > 1 && queue[0] === lastColor) {
              [queue[0], queue[1]] = [queue[1], queue[0]];
            }
          }
          const color = queue.shift();
          lastColor = color;
          return color;
        };

        this.poll.forEach((pollItem) => {
          if (!pollItem || !Array.isArray(pollItem.options)) return;
          pollItem.options.forEach((option) => {
            const key = `${pollItem.question}::${option}`;
            classes[key] = nextColor();
          });
        });
        this.optionPillClasses = classes;
      },
      getPillClass(question, option) {
        const key = `${question}::${option}`;
        return this.optionPillClasses[key] || this.pillColorClasses[0];
      },
      typein() {
          typeWriter(this.poll[0].question, 100, 
              (text) => { // Update callback
                  this.poll[0].question = text;
              },
              () => { // Completion callback
                  this.buttons = true
              }
          );
      },
      select(q,choice) {
        console.log(q, choice)
        this.choices.push({q,choice})
        this.vote({
          q: q,
          a: choice,
          index: this.index
        })
        this.index++
      },
      vote (obj) {
          console.log(obj)
          this.trackEvent(obj.q, obj.a)
      },
      sub() {
        console.log(this.choices, this.email)
        const url = 'https://olgdvvxouytdchveiaad.supabase.co/functions/v1/subscribe';
        const payload = { 
          params: this.choices, 
          email: this.email
        };

        fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Network response was not ok');
          }
          return response.json();
        })
        .then(data => {
          console.log(data);
          this.subscribed = true;
        })
        .catch(error => {
          console.error('There was a problem with the fetch operation:', error);
          this.message = 'Oops! Something went wrong. Please try again.';
        });

      },
        async trackEvent(question, answer) {
            const obj = {
                type : 'poll',
                action: 1,
                post_id: this.postId,
                item: {
                    question: question,
                    answer: answer, 
                }
            }
            beacontrack(obj)        
        },
      }
    }

    function splitText(text) {
        const words = text.split(' ');
        const halfIndex = Math.floor(words.length / 2);
        return [words.slice(0, halfIndex).join(' '), words.slice(halfIndex).join(' ')];
    }

{# function typeWriter(text, speed, updateCallback, completionCallback) {
    let i = 0;
    let currentText = '';

    function typing() {
        if (i < text.length) {
            currentText = text.substring(0, i + 1) + '_'; // Append underscore during typing
            updateCallback(currentText);
            i++;
            setTimeout(typing, speed);
        } else {
            updateCallback(text); // Update final text without underscore
            if (completionCallback) completionCallback(); // Call completion callback
        }
    }

    typing();
} #}
</script>
