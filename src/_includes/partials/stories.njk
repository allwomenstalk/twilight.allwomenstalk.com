<div x-data="popularstories" class="col-span-full">
  <div class="py-2 px-0 max-w-7xl mx-auto">
    <div class="flex items-center justify-between px-4">
      <h2 x-text="title" class="text-2xl font-bold tracking-tight">Trending</h2>
      <a href="https://allwomenstalk.com/stories" class="hidden text-sm font-semibold sm:block">
        All stories
        <span aria-hidden="true"> &rarr;</span>
      </a>
    </div>

    <div class="relative mt-2 ">
      <div class="relative -mb-6 w-full overflow-x-auto pb-6 no-scrollbar">
        <ul role="list" class="pr-4 pl-1 inline-flex space-x-3 ">
          
          <template x-for="item in list">
          <li class="inline-flex w-48 flex-col text-left">
            <a :href="item.url" target="_blank"  class="group block relative rounded-md overflow-hidden">
              <div class="h-full overflow-hidden bg-gray-200">
                <img :src="item.image" class="h-80 w-full object-cover object-center group-hover:opacity-75">
              </div>
              <div aria-hidden="true" class="absolute z-0 inset-x-0 bottom-0 h-36 bg-gradient-to-t from-black opacity-50"></div>
              <div class="mt-6 absolute p-2 bottom-0 text-sm">
                {# <p x-text="item.category" class="text-sm text-gray-500">Black</p> #}
                  <span x-text="item.title" class="text-white font-semibold"></span>
                
                {# <p class="mt-1 text-gray-900">$35</p> #}
              </div>
            </a>
          </li>
          </template>

          <!-- More products... -->
        </ul>
      </div>
    </div>

    <div class="mt-2 flex px-4 sm:hidden">
      <a href="https://allwomenstalk.com/stories" class="text-sm font-semibold sm:block">
        All stories
        <span aria-hidden="true"> &rarr;</span>
      </a>
    </div>
  </div>
</div>


<script>
function popularstories() {
  return {
    title: "Stories Trending Now ⚡️",
    list: [],
    init(){
      fetch('https://allwomenstalk.com/stories/list.json')
      .then(response => response.json())
      .then(data => {
        data.items.sort(() => Math.random() - 0.5);
        this.list = data.items.map (el=> {
          el.title = el.title.replace(/&#39;|[\uD800-\uDBFF][\uDC00-\uDFFF]|[\uD800-\uDFFF]/g, '');
          return el;
        });
        console.log(this.list);
      });
    }
  }
}
</script>