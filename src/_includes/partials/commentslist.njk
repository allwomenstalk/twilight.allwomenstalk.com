<div>
  <div>
    <button @click="getComments(true)" x-show="comment.loadall" x-cloak type="button" class="mx-auto rounded-md bg-pink-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
      Load all comments
    </button>
    <div class="mt-6 py-4">
      <div class="flow-root">
        <ul role="list" class="-mb-8">
          {% for comment in post.comments %}
            {% if comment.comment_content and (comment.comment_content | trim) %}
            <li x-show="commentstatic" class="mb-4">
              <div class="relative {% if not loop.last %}pb-8{% else %}pb-2{% endif %}">
                {% if not loop.last %}
                  <span aria-hidden="true" class="absolute left-5 top-10 -ml-px h-full w-0.5 bg-gray-200"></span>
                {% endif %}
                <div class="relative flex items-start space-x-3">
                  <div class="mt-1 flex size-10 items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-5 text-gray-400">
                      <path d="M1 8.74c0 .983.713 1.825 1.69 1.943.904.108 1.817.19 2.737.243.363.02.688.231.85.556l1.052 2.103a.75.75 0 0 0 1.342 0l1.052-2.103c.162-.325.487-.535.85-.556.92-.053 1.833-.134 2.738-.243.976-.118 1.689-.96 1.689-1.942V4.259c0-.982-.713-1.824-1.69-1.942a44.45 44.45 0 0 0-10.62 0C1.712 2.435 1 3.277 1 4.26v4.482Z" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1 -mt-1" x-data="{ expanded: false, overflow: false, init() { this.$nextTick(() => { const el = this.$refs.body; if (!el) return; this.overflow = el.scrollHeight > el.clientHeight + 2; }); } }">
                    <div class="flex items-center justify-between gap-3">
                      <div class="text-sm">
                        <span class="font-medium text-gray-900">{{ comment.comment_author }}</span>
                      </div>
                      <p class="text-xs text-gray-400 whitespace-nowrap" {% if comment.comment_date %}x-data="{ d: '{{ comment.comment_date | escape }}' }"{% endif %}>
                        {% if metadata.NODE_ENV != 'production' %}
                          <span class="text-[9px] opacity-70 mr-1 align-middle">#{{ comment._id }}</span>
                        {% endif %}
                        <span {% if comment.comment_date %}x-text="new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short' }).format(new Date(d))"{% endif %}>
                          {% if comment.comment_date %}
                            {{ comment.comment_date }}
                          {% else %}
                            Community comment
                          {% endif %}
                        </span>
                      </p>
                    </div>
                    <div class="mt-2 text-sm text-gray-700">
                      <div x-ref="body" class="leading-6 overflow-hidden" :style="expanded ? '' : 'max-height: 4.5rem;'">{{ comment.comment_content | safe }}</div>
                      <button x-show="overflow" x-cloak @click="expanded = !expanded" type="button" class="mt-1 inline-flex items-center rounded p-1 text-pink-600 hover:bg-pink-50 hover:text-pink-500" :aria-label="expanded ? 'Collapse comment' : 'Expand comment'">
                        <span class="sr-only" x-text="expanded ? 'Collapse comment' : 'Expand comment'"></span>
                        <svg x-show="!expanded" x-cloak viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0l-4.25-4.51a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                        </svg>
                        <svg x-show="expanded" x-cloak viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
                          <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 0 1-1.06-.02L10 8.832l-3.71 3.938a.75.75 0 1 1-1.08-1.04l4.25-4.51a.75.75 0 0 1 1.08 0l4.25 4.51a.75.75 0 0 1-.02 1.06Z" clip-rule="evenodd" />
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            {% endif %}
          {% endfor %}

          <template x-for="(item, index) in comments" :key="item._id || index">
            <li x-show="item.comment_content && item.comment_content.trim().length > 0" class="mb-4">
              <div class="relative pb-8">
                <span x-show="index < comments.length - 1" aria-hidden="true" class="absolute left-5 top-10 -ml-px h-full w-0.5 bg-gray-200"></span>
                <div class="relative flex items-start space-x-3">
                  <div class="mt-1 flex size-10 items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true" class="size-5 text-gray-400">
                      <path d="M1 8.74c0 .983.713 1.825 1.69 1.943.904.108 1.817.19 2.737.243.363.02.688.231.85.556l1.052 2.103a.75.75 0 0 0 1.342 0l1.052-2.103c.162-.325.487-.535.85-.556.92-.053 1.833-.134 2.738-.243.976-.118 1.689-.96 1.689-1.942V4.259c0-.982-.713-1.824-1.69-1.942a44.45 44.45 0 0 0-10.62 0C1.712 2.435 1 3.277 1 4.26v4.482Z" />
                    </svg>
                  </div>
                  <div class="min-w-0 flex-1 -mt-1" x-data="{ expanded: false, overflow: false, init() { this.$nextTick(() => { const el = this.$refs.body; if (!el) return; this.overflow = el.scrollHeight > el.clientHeight + 2; }); } }">
                    <div class="flex items-center justify-between gap-3">
                      <div class="text-sm">
                        <span class="font-medium text-gray-900" x-text="item.comment_author"></span>
                      </div>
                      <p class="text-xs text-gray-400 whitespace-nowrap">
                        {% if metadata.NODE_ENV != 'production' %}
                          <span class="text-[9px] opacity-70 mr-1 align-middle" x-text="'#' + (item._id || '-')"></span>
                        {% endif %}
                        <span x-text="item.comment_date ? new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short' }).format(new Date(item.comment_date)) : 'Community comment'"></span>
                      </p>
                    </div>
                    <div class="mt-2 text-sm text-gray-700">
                      <p x-ref="body" class="leading-6 overflow-hidden" :style="expanded ? '' : 'max-height: 4.5rem;'" x-text="item.comment_content"></p>
                      <button x-show="overflow" x-cloak @click="expanded = !expanded" type="button" class="mt-1 inline-flex items-center rounded p-1 text-pink-600 hover:bg-pink-50 hover:text-pink-500" :aria-label="expanded ? 'Collapse comment' : 'Expand comment'">
                        <span class="sr-only" x-text="expanded ? 'Collapse comment' : 'Expand comment'"></span>
                        <svg x-show="!expanded" x-cloak viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0l-4.25-4.51a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                        </svg>
                        <svg x-show="expanded" x-cloak viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
                          <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 0 1-1.06-.02L10 8.832l-3.71 3.938a.75.75 0 1 1-1.08-1.04l4.25-4.51a.75.75 0 0 1 1.08 0l4.25 4.51a.75.75 0 0 1-.02 1.06Z" clip-rule="evenodd" />
                        </svg>
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          </template>
        </ul>
      </div>
    </div>
  </div>
</div>
