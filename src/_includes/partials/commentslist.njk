<div class="bg-white">
  <div class="" >
    <button @click="getComments(true)" x-show="comment.loadall" type="button" class="mx-auto rounded-md bg-pink-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
    Load all comments
    </button>
    <div class="mt-6 space-y-4 divide-gray-200 border-b border-t border-gray-200 pb-4" >
      
      {# Static comments #}
      {% for comment in post.comments %}
      <div x-show="commentstatic" class="">
        <div class=" ">
          <div class="mt-4  xl:col-span-2 xl:mt-0">
            {# <h3 class="text-sm font-medium text-gray-900">Can&#039;t say enough good things</h3> #}

            <div class="mt-3 space-y-6 text-sm text-gray-500">
             <span class="font-medium text-gray-900">{{ comment.comment_author }}:</span> 
             <span>{{ comment.comment_content | safe }}</span>
            </div>
          </div>
        </div>
        {# <div class="mt-2 flex items-center text-sm xl:col-span-3">
          <p class="font-medium text-gray-900">{{ comment.comment_author }}</p>
          <time datetime="2021-01-06" class="ml-4 border-l border-gray-200 pl-4 text-gray-500    ">May 16, 2021</time>
        </div> #}
      </div>
      {% endfor %}
      <!-- More ... -->
      
      {# Dynamic comments #}
      <template x-for="item in comments">
          <div class="">
              <div class=" ">
                  <div class="mt-4  xl:col-span-2 xl:mt-0">

                      <!-- Uncomment this if you want to use title in the future -->
                      <!-- <h3 class="text-sm font-medium text-gray-900">Can&#039;t say enough good things</h3> -->

                      <div class="mt-3 space-y-6 text-sm text-gray-500">
                          <span class="font-medium text-gray-900" x-text="item.comment_author"></span>: <span x-text="item.comment_content"></span>
                      </div>
                  </div>
              </div>
              {# <div class="mt-2 flex items-center text-sm xl:col-span-3">
                  <span class="font-medium text-gray-900" x-text="item.comment_author"></span>

                  <!-- Uncomment this if you want to use date in the future -->
                  <!-- <time datetime="2021-01-06" class="ml-4 border-l border-gray-200 pl-4 text-gray-500">May 16, 2021</time> -->

              </div> #}
          </div>
      </template>

      
    </div>
  </div>
</div>


