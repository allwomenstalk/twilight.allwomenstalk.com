<div class="my-12">
        <p class="uppercase tracking-wide text-sm opacity-70 font-bold text-center" id="ratingtitle">Please rate this article</p>
        <div class="rating mx-auto text-pink-600 text-2xl tracking-wide" id="rating">
            <span @click="rate(5)">☆</span>
            <span @click="rate(4)">☆</span>
            <span @click="rate(3)">☆</span>
            <span @click="rate(2)">☆</span>
            <span @click="rate(1)">☆</span>
        </div>
    </div>
    
    <style>
    .rating {
        unicode-bidi: bidi-override;
        direction: rtl;
        text-align:center
    }

    .rating > span {
        display: inline-block;
        position: relative;
        width: 1em;
        cursor:pointer
    }

    .rating > span:hover:before, .rating > span:hover ~ span:before {
        content: "★";
        position: absolute
    }
    </style>
    <script>
    function SR(e) {
        document.getElementById("rating").innerHTML = "☆".repeat(5 - e) + "★".repeat(e),
        document.getElementById("ratingtitle").innerHTML = "Thanks!"
        console.log(e)
    }
    </script>
    