
<div x-data="productApp()" class="bg-white">
  <div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 sm:py-24 lg:max-w-7xl lg:px-8">
    <h2 x-html="title" class="text-2xl py-4 font-bold tracking-tight text-gray-900"></h2>

    <div class="overflow-x-auto pb-4">
      <div class="w-[1200px] grid grid-cols-6 gap-x-6 gap-y-10" >
        <template x-for="product in products" :key="product.id">
          <a
          href="#"
          @click.prevent="trackAndRedirect(product)"
          class="group">
            <img :src="product.image" :alt="product.title" class="aspect-square w-full rounded-lg bg-gray-200 object-cover group-hover:opacity-75 xl:aspect-[7/8]">
            <h3 class="mt-4 text-sm text-gray-700" x-text="product.title"></h3>
            <p class="mt-1 text-lg font-medium text-gray-900" x-text="`$${product.price}`"></p>
          </a>
        </template>
      </div>
    </div>
  </div>
</div>

<script>
  function productApp() {
    return {
      products: [],
      title: 'Trending products',
      merchants: [],

      async fetchMerchants() {
        try {
          // Fetch the merchant data from /data.json
          const response = await fetch('/data.json');
          this.merchants = await response.json();
        } catch (error) {
          console.error('Error loading data.json:', error);
        }
      },

      async fetchRandomProducts() {
        {# if (this.merchants.length === 0) {
          console.warn('No merchants available.');
          return;
        } #}

        // Pick a random merchant from the fetched data
        // const randomMerchant = this.merchants[Math.floor(Math.random() * this.merchants.length)];
        const randomMerchant = await fetch("https://trendingproudcts.iniret.workers.dev").then(res => res.json());

        const name = randomMerchant.merchant_name;
        const homepage = randomMerchant.homepage;
        const product_url = randomMerchant.products_url;

        {# this.title = `Trending products from <a href="${homepage}" target="_blank" rel="noopener noreferrer">${name}</a>`; #}


        try {
          // Fetch products from the merchant's products_url
          const response = await fetch(product_url);
          const data = await response.json();

          // Process the fetched products to fit the template
          this.products = data.products.map(product => ({
            id: product.id,
            title: product.title,
            // image: product.images[0]?.src || 'https://via.placeholder.com/300',
            image: product?.featured_image?.src || product.images[0]?.src,
            price: product.variants[0]?.price || "FREE",
            body_html: product.body_html,
            link : product.handle ? `${homepage}/products/${product.handle}` : homepage,
            url: generateDigidipLink(product.handle ? `${homepage}/products/${product.handle}` : homepage, document.referrer, window.location.href)
          }))
          .sort(() => Math.random() - 0.5)
          .slice(0, 6)
          


        } catch (error) {
          console.error('Error fetching products:', error);
        }
      },

      async trackAndRedirect(product) {
        // Send the tracking event
        await this.track(product);

        // Then redirect to the affiliate link
        window.location.href = product.url;
      },

      track(item) {
        const data = JSON.stringify({
            url: item.link,
            title: item.title,
            price: item.price,
            page: window.location.href
        });

        const endpoint = 'https://botnotify.iniret.workers.dev/';
        
        // Use sendBeacon instead of fetch
        const success = navigator.sendBeacon(endpoint, data);

        if (!success) {
            console.error('Beacon send failed.');
        }
      },

      async init() {
        // Load merchants from /data.json, then load products
        {# await this.fetchMerchants(); #}
        await this.fetchRandomProducts();
      }
    };
  }


  function generateDigidipLink(destinationUrl, referrerUrl, currentPageUrl) {
    // Base Digidip endpoint
    const digidipBase = "https://allwomenstalk.digidip.net/visit";

    // URL encode the parameters
    const encodedUrl = encodeURIComponent(destinationUrl);
    const encodedReferrer = encodeURIComponent(referrerUrl);
    const encodedCurrent = encodeURIComponent(currentPageUrl);

    // Construct the full affiliate link
    const affiliateLink = `${digidipBase}?url=${encodedUrl}&ppref=${encodedReferrer}&currurl=${encodedCurrent}`;

    return affiliateLink;
    }
</script>

