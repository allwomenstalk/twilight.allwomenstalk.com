<div id="commentform">
 
  <div class="flex items-start space-x-3">
    <div class="size-10 shrink-0" aria-hidden="true"></div>
    <div class="min-w-0 flex-1">
      <form @submit.prevent="commentSubmit" x-data="{ detailsOpen: false }" class="relative grid gap-4">
        <div class="overflow-hidden rounded-md">
        <label for="comment" class="sr-only">Add your comment</label>
        <textarea
          @focus="detailsOpen = true"
          rows="5"
          name="comment"
          x-model="comment.comment_content"
          id="comment"
          class="block w-full resize-none rounded-md border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 shadow-sm focus:border-pink-500 focus:ring-pink-500"
          placeholder="Add your comment..."></textarea>
        </div>


        <div
          x-show="detailsOpen && comment.use_profile_identity"
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 -translate-y-1"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-700"
        >
          Commenting as <strong x-text="comment.comment_author"></strong>
        </div>

        <div id="addcomment" x-show="detailsOpen && !comment.use_profile_identity" x-cloak x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-1" x-transition:enter-end="opacity-100 translate-y-0" class="grid gap-3 rounded-md text-xs md:grid-cols-2">
          <div class="relative">
            <input x-model="comment.comment_author" :readonly="comment.use_profile_identity" :required="!comment.use_profile_identity" type="text" name="name" id="name" pattern=".{5,}" title="Name must be at least 5 characters long" class="block w-full rounded-md border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 shadow-sm focus:border-pink-500 focus:ring-pink-500 read-only:bg-gray-50" :placeholder="comment.use_profile_identity ? 'Name from profile' : 'Name (at least 5 characters)'">
          </div>
          <div class="relative">
            <input x-model="comment.comment_author_email" :readonly="comment.use_profile_identity" type="email" name="job-title" id="job-title" class="block w-full rounded-md border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder:text-gray-400 shadow-sm focus:border-pink-500 focus:ring-pink-500 read-only:bg-gray-50" :placeholder="comment.use_profile_identity ? 'Email from profile' : 'Email (optional)'">
          </div>
        </div>


        <div class="flex-shrink-0">
          <button :disabled="comment.disable" 
            :class="{'cursor-not-allowed opacity-70':comment.disable}"
            class="inline-flex items-center rounded-md  px-3 py-2 text-sm font-semibold text-white bg-pink-600">
            Comment
          </button>
        </div>
      </form>
    </div>
  </div>





</div>

