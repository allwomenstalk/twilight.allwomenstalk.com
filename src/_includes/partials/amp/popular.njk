<p class="uppercase tracking-wide text-sm opacity-70 font-bold text-center mt-8">Popular now</p>
  <div class="overflow-x-scroll mb-6 py-4 no-scrollbar roll">
  <amp-list width="980px"  src="https://allwomenstalk.com/popular/list.json" height="200" layout="responsive" style="min-width: 980px"> 

    <template type="amp-mustache">
      <a href="{{ampurl}}" class="block m-2 w-44 bg-gray-100 hover:bg-white rounded-lg relative">
             <span class="tracking-wide uppercase absolute z-10 bg-black text-white px-1 m-1 rounded opacity-70 text-xs">{{ampcategory}}</span>
             <div class="text-center overflow-hidden bg-cover bg-center rounded-t ">
               <amp-img
                   class="w-full ls-is-cached "
                   src="{{ampimage}}?width=400&height=400"
                   alt="{{amptitle}}"
                   layout="responsive"
                   width="200"
                   height="200">
               </amp-img>
             </div>
             <div class="rounded-b p-4 h-32 overflow-hidden">
               <span class="uppercase text-gray-900 mb-2">{{amptitle}}</span>
             </div>
         </a>
    </template>
  </amp-list>
</div>

