<div class="hero mb-6 overflow-hidden bg-gray-50">
  <div class="grid gap-y-8 md:gap-y-16 mx-auto mt-2 p-6 align-middle relative bg-gradient-to-b">
    <div class="px-4 flex justify-between uppercase tracking-wide text-sm font-bold text-gray-800 opacity-90">
      <a href="https://{{ post.category[0] }}.allwomenstalk.com/">{{ post.category[0] }}</a>
      <a href="#rating">{{ post.ratingstars }}</a>
    </div>
    <h1 class="post-title mx-auto max-w-2xl font-bold text-4xl leading-tight py-2 md:text-6xl md:text-center overflow-hidden">
      {{ post.viral or post.title }}
    </h1>
  </div>
  
  <div class="relative mx-auto overflow-hidden">
    {% if post.video_url %}
      <!-- AMP Video -->
      <div class="relative z-10">
        <amp-video 
          class="w-full sm:rounded-xl object-cover max-w-xl mx-auto h-full"
          autoplay 
          loop 
          muted
          poster="{{ post.image }}"
          width="{{ post.imagesize.width or 800 }}" 
          height="{{ post.imagesize.height or 600 }}">
          <source src="{{ post.video_url }}" type="video/mp4">
          <div fallback>
            <amp-img src="{{ post.image }}" alt="{{ post.title }}" layout="responsive" width="{{ post.imagesize.width or 800 }}" height="{{ post.imagesize.height or 600 }}"></amp-img>
          </div>
        </amp-video>
      </div>
    {% elif post.image %}
      <!-- AMP Image -->
      <div class="relative z-10">
        <amp-img 
          class="w-full sm:rounded-xl object-cover max-w-xl mx-auto h-full"
          src="{{ post.image }}" 
          alt="{{ post.title }}" 
          width="{{ post.imagesize.width or 800 }}" 
          height="{{ post.imagesize.height or 600 }}"
          layout="responsive">
        </amp-img>
      </div>
    {% endif %}
    
    <!-- Author and Date under image -->
    <div class="mt-4 max-w-xl mx-auto px-4">
      <div class="flex justify-between items-center text-sm text-gray-600">
        <span class="flex items-center whitespace-nowrap">
          <span class="text-gray-600 mr-1">By</span>
          <a href="https://allwomenstalk.com/profile/{{ post.author.id }}/" class="text-gray-800 hover:text-pink-600 font-medium">{{ post.author.name }}</a>
          {% if post.date and (post.date | isWithinLastYear) %}
            <span class="text-gray-600 ml-2">
              • {{ post.date | formatDate }}
            </span>
          {% endif %}
        </span>
        
        <!-- AMP Social Share buttons -->
        <span class="isolate inline-flex rounded-md shadow-sm">
          <amp-social-share 
            type="system"
            width="40"
            height="32"
            class="relative inline-flex items-center rounded-l-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300">
          </amp-social-share>
        </span>
      </div>
    </div>
  </div>
</div>
