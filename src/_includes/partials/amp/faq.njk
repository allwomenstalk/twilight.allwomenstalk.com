{% if post.faq and post.faq.length > 0 %}
<div class="max-w-xl mx-auto">
  <div class="mx-auto px-4 py-12">
    <div class="mx-auto max-w-4xl">
      <h2 class="text-2xl font-bold leading-10 tracking-tight text-gray-900 mb-8">Frequently Asked Questions</h2>
      <dl class="space-y-8">
        {% for item in post.faq %}
        <div class="pt-6 border-t border-gray-200">
          <dt class="text-base font-semibold leading-7 text-gray-900 mb-2">
            {{item.question}}
          </dt>
          <dd class="mt-2 text-base leading-7 text-gray-600">
            {{item.answer}}
          </dd>
        </div>
        {% endfor %}
      </dl>
    </div>
  </div>
</div>
{% endif %}
