<div class="max-w-screen-xl mx-auto p-4">
  <div class="viral-slideshow-wrap">
    <section
      id="viral-slide"
      x-data='viralSlideshow({{ viralItems | json | safe }})'
      x-init="init()"
      class="viral-slide-root relative isolate overflow-hidden rounded-[inherit]">
    <a id="viral-slide-link" :href="currentUrl" target="_blank" rel="noopener noreferrer" class="absolute inset-0 z-40" aria-label="Open article"></a>
    <div class="viral-slide-bg" aria-hidden="true">
      <img id="viral-img-0" class="viral-seq-image viral-bg-img" loading="lazy" :src="currentImages[0] || ''" :alt="titleText + ' image 1'" />
      <img id="viral-img-1" class="viral-seq-image viral-bg-img" loading="lazy" :src="currentImages[1] || currentImages[0] || ''" :alt="titleText + ' image 2'" />
      <img id="viral-img-2" class="viral-seq-image viral-bg-img" loading="lazy" :src="currentImages[2] || currentImages[0] || ''" :alt="titleText + ' image 3'" />
      <img id="viral-img-3" class="viral-seq-image viral-bg-img" loading="lazy" :src="currentImages[3] || currentImages[0] || ''" :alt="titleText + ' image 4'" />
      <img id="viral-img-4" class="viral-seq-image viral-bg-img" loading="lazy" :src="currentImages[4] || currentImages[0] || ''" :alt="titleText + ' image 5'" />
    </div>
    <div class="viral-slide-overlay" aria-hidden="true"></div>
    <div id="viral-slide-shell" class="viral-slide-fade-shell relative z-20 pointer-events-none mx-auto max-w-7xl px-6 py-10 sm:py-12 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
        <div class="relative flex min-h-[20rem] w-full flex-col justify-between lg:max-w-xl lg:shrink-0 xl:max-w-2xl">
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-pink-600">Feature</p>
            <h2 id="viral-slide-title" x-ref="title" x-text="titleText" class="text-pretty text-4xl font-semibold tracking-tight text-white sm:text-5xl"></h2>
          </div>
          <p>
            <span id="viral-slide-cta" x-ref="cta" class="inline-flex items-center rounded-md bg-pink-600 px-4 py-2 text-sm font-semibold text-white shadow-sm">Open article</span>
          </p>
        </div>
      </div>
    </div>
    </section>
  </div>
</div>

<style>
  .viral-slide-root,
  .viral-slide-root * {
    box-sizing: border-box;
  }

  .viral-slideshow-wrap {
    border-radius: 1.25rem;
    border: 1px solid #e2e8f0;
    background: #0b1220;
    box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  .viral-slide-root {
    background: #0b1220;
  }

  .viral-slide-bg {
    position: absolute;
    inset: 0;
    display: flex;
  }

  .viral-bg-img {
    width: 20% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center;
  }

  .viral-slide-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(3, 7, 18, 0.92) 0%, rgba(15, 23, 42, 0.88) 36%, rgba(30, 41, 59, 0.8) 52%, rgba(30, 41, 59, 0.72) 66%, rgba(30, 41, 59, 0.68) 78%, rgba(30, 41, 59, 0.64) 100%);
  }

  /* Force isolation from broad image rules used elsewhere on the site */
  .viral-slide-root img.viral-seq-image {
    display: block;
    width: auto;
    max-width: none !important;
    height: 100%;
    object-fit: cover;
    margin: 0 !important;
    background: transparent !important;
    border-radius: 0 !important;
  }

  @media (max-width: 1023px) {
    .viral-slide-root {
      min-height: 26rem;
    }
  }

  @media (max-width: 639px) {
    .viral-slide-root {
      min-height: 22rem;
    }
    .viral-slide-overlay {
      background:
        linear-gradient(90deg, rgba(3, 7, 18, 0.94) 0%, rgba(15, 23, 42, 0.9) 52%, rgba(30, 41, 59, 0.82) 75%, rgba(30, 41, 59, 0.72) 100%);
    }
  }

  .viral-seq-word,
  .viral-seq-fade,
  .viral-seq-image {
    opacity: 0;
    filter: blur(12px);
    transition: opacity 560ms cubic-bezier(0.19, 1, 0.22, 1), filter 560ms cubic-bezier(0.19, 1, 0.22, 1), transform 560ms cubic-bezier(0.19, 1, 0.22, 1);
    will-change: opacity, filter, transform;
  }
  .viral-seq-word {
    display: inline-block;
  }
  .viral-seq-fade {
    transform: translate3d(0, 0.35rem, 0);
  }
  .viral-seq-image {
    transform: translate3d(0, 1rem, 0) scale(0.98);
  }
  .viral-is-visible {
    opacity: 1;
    filter: blur(0);
    transform: translate3d(0, 0, 0) scale(1);
  }
  .viral-slide-fade-shell {
    opacity: 1;
    transition: opacity 1200ms ease;
  }
  .viral-slide-fade-shell.viral-is-fading {
    opacity: 0;
  }
</style>

<script>
  document.addEventListener("alpine:init", function () {
    Alpine.data("viralSlideshow", function (items) {
      return {
        items: Array.isArray(items) ? items : [],
        index: 0,
        featureOrder: [],
        orderPos: 0,
        titleText: "",
        currentUrl: "#",
        currentImages: [],
        durationVisibleMs: 3600,
        wordStepMs: 70,
        cycleTimer: null,
        init() {
          if (!this.items.length) return;
          this.shuffleFeatureOrder();
          this.applySlide(this.nextFeatureIndex());
          this.$nextTick(() => {
            this.animateIn();
            this.scheduleNext();
          });
        },
        shuffleFeatureOrder() {
          this.featureOrder = this.items.map((_, i) => i);
          for (let i = this.featureOrder.length - 1; i > 0; i -= 1) {
            const j = Math.floor(Math.random() * (i + 1));
            const tmp = this.featureOrder[i];
            this.featureOrder[i] = this.featureOrder[j];
            this.featureOrder[j] = tmp;
          }
          this.orderPos = 0;
        },
        nextFeatureIndex() {
          if (!this.featureOrder.length || this.orderPos >= this.featureOrder.length) {
            this.shuffleFeatureOrder();
          }
          const idx = this.featureOrder[this.orderPos];
          this.orderPos += 1;
          return idx;
        },
        shuffleImages(images) {
          const list = Array.isArray(images) && images.length ? [...images] : [""];
          while (list.length < 5) list.push(list[0] || "");
          for (let i = list.length - 1; i > 0; i -= 1) {
            const j = Math.floor(Math.random() * (i + 1));
            const tmp = list[i];
            list[i] = list[j];
            list[j] = tmp;
          }
          return list.slice(0, 5);
        },
        clearSeqState() {
          this.$el.querySelectorAll(".viral-is-visible").forEach((el) => el.classList.remove("viral-is-visible"));
          const shell = this.$el.querySelector("#viral-slide-shell");
          if (shell) shell.classList.remove("viral-is-fading");
          if (this.$refs.title && this.$refs.title.dataset.raw) this.$refs.title.textContent = this.$refs.title.dataset.raw;
        },
        prepareWords(el) {
          const text = (el.textContent || "").replace(/\s+/g, " ").trim();
          el.dataset.raw = text;
          el.textContent = "";
          const words = text ? text.split(" ") : [];
          const frag = document.createDocumentFragment();
          words.forEach((word, i) => {
            const span = document.createElement("span");
            span.className = "viral-seq-word";
            span.textContent = word;
            frag.appendChild(span);
            if (i !== words.length - 1) frag.appendChild(document.createTextNode(" "));
          });
          el.appendChild(frag);
          return Array.from(el.querySelectorAll(".viral-seq-word"));
        },
        applySlide(nextIndex) {
          const item = this.items[nextIndex] || {};
          this.index = nextIndex;
          this.titleText = item.title || "";
          this.currentUrl = item.url || "#";
          this.currentImages = this.shuffleImages(item.images);
        },
        animateIn() {
          const title = this.$refs.title;
          const cta = this.$refs.cta;
          if (!title || !cta) return;
          const words = this.prepareWords(title);
          const images = Array.from(this.$el.querySelectorAll(".viral-seq-image"));
          words.forEach((word, i) => {
            setTimeout(() => word.classList.add("viral-is-visible"), i * this.wordStepMs);
          });
          const titleDone = Math.max(0, words.length - 1) * this.wordStepMs + 560;
          setTimeout(() => cta.classList.add("viral-seq-fade", "viral-is-visible"), titleDone + 120);
          images.forEach((img, i) => {
            setTimeout(() => img.classList.add("viral-is-visible"), titleDone + 280 + i * 120);
          });
        },
        animateOut() {
          const shell = this.$el.querySelector("#viral-slide-shell");
          if (shell) shell.classList.add("viral-is-fading");
        },
        scheduleNext() {
          if (this.cycleTimer) clearTimeout(this.cycleTimer);
          this.cycleTimer = setTimeout(() => {
            this.animateOut();
            setTimeout(() => {
              this.clearSeqState();
              const next = this.nextFeatureIndex();
              this.applySlide(next);
              this.$nextTick(() => {
                this.animateIn();
                this.scheduleNext();
              });
            }, 1200);
          }, this.durationVisibleMs);
        }
      };
    });
  });
</script>
