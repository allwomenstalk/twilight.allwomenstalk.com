<div @scroll.window="handleScroll" x-init="loadposts('{{ category }}')" class="">
  <template x-for="list in posts">
    <div class="col-span-full grid grid-cols-2 gap-4 sm:grid-cols-3 md:gap-8 lg:grid-cols-6 lg:gap-4 xl:gap-8 p-4 max-w-screen-xl
        mx-auto">
      <template x-for="(post, index) in list" :key="index">
        <a
          :href="post.url ? post.url : null"
          @click="post.url ? null : (select(post), $event.preventDefault())"
          :title="post.title"
          class="text-gray-900 rounded-2xl hover:opacity-70 relative "
          :class="{'col-span-full sm:grid grid-cols-2 h-88': index % 7 === 6}">
          <div
            class="aspect-w-1 aspect-h-1 w-full aspect-square overflow-hidden bg-cover bg-center relative"
            :class="{ 'rounded-b-2xl' : post.type == 'feed', 'rounded-t-2xl sm:rounded-tl-2xl sm:rounded-bl-2xl sm:rounded-tr-none sm:rounded-br-none h-96': index % 7 === 6, 'rounded-t-2xl h-48 ':
              index % 7 !== 6 }">
            <img
              class="object-cover w-full h-full"
              :class="post.hue ? post.hue : ''"
              :src="post.image"
              :alt="post.title"
              loading="lazy"
              decoding="async"><!-- saturate-200 -hue-rotate-[30deg] hue-rotate-[30deg] hue-rotate-[45deg] hue-rotate-[60deg] hue-rotate-[90deg]
                hue-rotate-[180deg] hue-rotate-[240deg] hue-rotate-[270deg] hue-rotate-[300deg] -->
            </div>
            <div
              class="border border-gray-300 rounded-b-2xl p-4 flex flex-col justify-between leading-normal h-56 cardtitle bg-white
                dark:bg-gray-900"
              :class="{ 'absolute top-0 bg-opacity-0 text-white text-sm sm:text-lg lg:text-base font-bold border-0': post.type ==
                'feed', 'text-xs': post.type != 'feed', 'md:border-l-0 sm:rounded-r-2xl sm:rounded-l-none sm:h-full': index % 7 === 6 }">
              <div>
                <p
                  class="inline-flex items-center rounded-full px-1.5 py-0.5 text-[8px] font-medium uppercase ring-1 ring-inset"
                  :class="{
                    'bg-rose-50 text-rose-700 ring-rose-200': index % 8 === 0,
                    'bg-amber-50 text-amber-700 ring-amber-200': index % 8 === 1,
                    'bg-emerald-50 text-emerald-700 ring-emerald-200': index % 8 === 2,
                    'bg-sky-50 text-sky-700 ring-sky-200': index % 8 === 3,
                    'bg-violet-50 text-violet-700 ring-violet-200': index % 8 === 4,
                    'bg-fuchsia-50 text-fuchsia-700 ring-fuchsia-200': index % 8 === 5,
                    'bg-orange-50 text-orange-700 ring-orange-200': index % 8 === 6,
                    'bg-lime-50 text-lime-700 ring-lime-200': index % 8 === 7
                  }"
                  x-text="post.category"><!-- Category will be dynamically filled -->
                </p>
                <h2
                  class="my-2 font-display"
                  :class="{'text-xl capitalize font-bold sm:text-3xl lg:text-5xl': index % 7 === 6, 'text-sm': index % 7 !== 6}"
                  x-text="post.title"><!-- Title will be dynamically filled by Alpine.js -->
                </h2>
              </div>
              <div class="flex items-end justify-between gap-3">
                <div x-show="post.date && index % 7 === 6" class="flex items-center opacity-70">
                  <div class="text-xs">
                    <p class="leading-none" x-text="formattedDate(post.date)"></p>
                  </div>
                </div>
                <span
                  x-show="index % 7 === 6"
                  class="inline-flex items-center text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                  </svg>
                </span>
              </div>
              <div x-show="index % 7 !== 6" class="mt-3 flex justify-end">
                <span
                  class="inline-flex items-center text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </template>
        <!-- Static widget sections that appear between post loads -->
        <div class="w-full my-2 lg:my-12 col-span-full  mx-auto px-0 ">
          {% include 'partials/spins/widget.njk' %}
        </div>
      </div>
    </template>
  </div>
  <div x-show="loading" class="text-center my-12">
    {% include "partials/spinner.njk" %}
  </div>
  {% include "partials/modal.njk" %}
