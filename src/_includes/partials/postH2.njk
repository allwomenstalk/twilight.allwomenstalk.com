<div x-data='{saved:false}' class="relative mt-24 max-w-xl px-4 sm:px-8 mx-auto" id="0">
    <div class="bg-white text-pink-400 text-xl font-bold rounded-full w-12 h-12 absolute top-8 right-12 sm:right-16 flex items-center justify-center text-center">
        {{page.number}}
    </div>
    <div class="min-h-[20rem] md:min-h-[20rem] h-auto  pr-12 grid place-items-end rounded-lg bg-gradient-to-r from-amber-300 to-pink-400">
        {#  #}
        <h3 class="text-black p-9 sm:p-12 pr-20 text-left w-full text-3xl sm:text-4xl font-bold">
            {{page.title | safe }}
        </h3>
    </div>
    <button @click="savepoint('{{post.id}}', `{{page.title}}`, {{page.number}}, saved);saved=true" type="button" class="absolute bottom-2 right-8 inline-flex items-center gap-x-1.5 rounded-md  px-3 py-2 text-sm font-semibold text-white focus:z-10">
        <span x-text="saved?'Saved':'Save'"></span>
        <svg  x-show="!saved" class="-ml-0.5 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
        </svg>
        <svg x-show="saved" class="-ml-0.5 h-5 w-5 text-white"xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
            <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0 1 11.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 0 1-1.085.67L12 18.089l-7.165 3.583A.75.75 0 0 1 3.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93Z" clip-rule="evenodd" />
        </svg>
    </button>
</div>