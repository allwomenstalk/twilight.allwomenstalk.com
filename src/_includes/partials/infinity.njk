<div x-data="infinity" class="max-w-2xl mx-auto mt-16 sm:rounded-t-xl">
        <template x-for="(item, index) in list" :key="index">
            <div x-show="!item.hidden" class="my-8 sm:my-16">
                <figure class="mx-4 overflow-hidden rounded-xl">
                    <img :src="item.image" alt="" class="aspect-square md:aspect-[16/9] lg:aspect-[3/2] w-full bg-gray-100 object-cover">
                </figure>
                {# <textarea x-model="JSON.stringify(item,null,4)"></textarea> #}
                <a :href="item.url" x-html="item.title" class="mx-4 block py-4 max-w-md text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"></a>
                <article x-data="{show:index==0}" :class="{'h-[400px]': !show, 'h-auto': show}" class="prose post mx-4 relative overflow-hidden border-3 border-red-500">
                    
                    <section x-html="item.html" :id="'article-' + index"></section>
                    <div x-show="!show" class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-gray-50 via-gray-50/90 to-transparent"></div>
                    <button x-show="!show" @click="show=expand()" class="absolute bottom-2 left-0f bg-black text-white text-sm font-semibold px-4 py-2 rounded-lg shadow-md">Continue reading</button>
                </article>
            </div>
        </template>
    </div>
    <script>
    console.log('infinity');
    function infinity() {
        return {
            list: [],
            url: 'https://beauty.allwomenstalk.com/carriere-freres-solid-soaps/',
            category: 'beauty',
            page: 0,
            init() {
                console.log('init infinity');
                this.loadlist();
            },
            loadlist() {
                url = `https://pub-ff359827c45e40a7b6e9bad1878cd18a.r2.dev/posts/${(this.category ? this.category : '')}/${this.page}.json`;
                console.log('url', url);
                fetch(url)
                .then(response => {
                    return response.json();
                })
                .then(data => {
                    console.log('data', data);
                    arr = data.filter(item => item.url !== this.url)
                    .sort(() => Math.random() - 0.5);
                    this.list.push(...arr);
                    console.log('list', this.list);
                    this.$nextTick(() => {
                        this.list.forEach((item, index) => {
                            item.html = '';
                            this.observeArticle(index);
                        });
                    });
                })
                .catch(error => {
                    console.error('Error fetching data:', error);
                });
            },
            getarticle(url, index) {
                console.log('getarticle', url);

                fetch(url)
                    .then(response => response.text())
                    .then(html => {
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const pages = doc.querySelectorAll('article.post.prose');
                        let content = '';

                        pages.forEach((page) => {
                            content += page.innerHTML;
                        });

                        if (this.list[index]) {
                            this.list[index].html = content || ""; // Assign content or default text if empty
                            console.log('html content', this.list[index].html);

                            if (this.list[index].html.length < 10) {
                                console.log('length', this.list[index].html.length )
                                this.list[index].hidden = true

                            }
                        }
                    })
                    .catch(error => {
                        console.error('Error fetching data:', error);
                    });

                // If this is the last article, load more
                if (index === this.list.length - 1) {
                    this.page++;
                    this.loadlist();
                }
            },
            observeArticle(index) {
                this.$nextTick(() => {
                    const articleElement = document.getElementById('article-' + index);
                    if (articleElement) {
                        const observer = new IntersectionObserver((entries) => {
                            entries.forEach(entry => {
                                if (entry.isIntersecting) {
                                    url = this.list[index].url

                                    this.getarticle(url, index);
                                    // set browser url to the article url
                                    // window.history.pushState({}, '', '/' + this.list[index].slug + '/');

                                    observer.unobserve(entry.target);
                                }
                            });
                        }, {
                            rootMargin: '0px 0px 200px 0px',
                            // Start loading before the article is fully in view
                            threshold: 0.1
                        });
                        observer.observe(articleElement);
                    }
                });
            },
            async expand() {
                event = {
                    label: 'expand',
                    page: window.location.pathname,
                }
                obj = {
                    type: 'infinity',
                    action: 1,
                    post_id: "",
                    item: event
                }
                this.beacontrack(obj);
                return true;

            },
            beacontrack(obj) {
                const trackapi = `https://us-central1.gcp.data.mongodb-api.com/app/allwomenstalk-ebogu/endpoint/beacon`;

                // Use sendBeacon for sending the tracking data
                const beaconData = new Blob([JSON.stringify(obj)], {
                    type: 'application/json'
                });
                const success = navigator.sendBeacon(trackapi, beaconData);

            },
            subscribe: [
            "",
            ],
            cta: [
            "",
            ]
        };
    }
    </script>