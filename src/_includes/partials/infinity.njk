<div x-data="infinity" class="max-w-2xl sm:px-4 mx-auto mt-16 sm:rounded-t-xl">
        <template x-for="(item, index) in list" :key="index">
            <div x-show="!item.hidden" class="my-8 sm:my-16">
                <figure x-show="item.image" class="mx-4 overflow-hidden rounded-xl">
                    <img :src="item.image" alt="" class="aspect-square md:aspect-[16/9] lg:aspect-[3/2] w-full bg-gray-100 object-cover">
                </figure>
                <a x-html="item.title" class="mx-4 block py-4 max-w-md text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"></a>
                <article x-data="{show:item.exists}" :class="{'h-[200px]': !show, 'h-auto': show}" class=" mx-4 relative overflow-hidden border-3 border-red-500">
                    <section x-show="!item.html" x-html="item.excerpt" :id="'excerpt-' + index"></section>
                    {# outline #}
                    <ul x-show="item.outline && !item.html" class="list-disc list-inside divide-y">
                        <template x-for="item in item.outline">
                            <li x-text="item"></li>
                        </template>
                    </ul>
                    <section x-html="item.html" :id="'article-' + index" class="prose"></section>
                    <div x-show="!show" class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-gray-50 via-gray-50/90 to-transparent"></div>
                    <button x-show="!show" @click="show=expand(item)" class="absolute bottom-2 left-0f bg-black text-white text-sm font-semibold px-4 py-2 rounded-lg shadow-md">Continue reading</button>
                </article>

                {# <pre x-text="JSON.stringify(item, null, 4)" class='text-xs'></pre> #}

            </div>
        </template>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/showdown/2.1.0/showdown.min.js" integrity="sha512-LhccdVNGe2QMEfI3x4DVV3ckMRe36TfydKss6mJpdHjNFiV07dFpS2xzeZedptKZrwxfICJpez09iNioiSZ3hA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
    console.log('infinity');
    var converter = new showdown.Converter();
    function infinity() {
        return {
            list: [],
            url: "{{post.url}}",
            postid: "{{post.id}}",
            category: "{{post.category[0]}}",
            page: 0,
            init() {
                console.log('Infinity initialized');
                this.loadList();
            },
            async loadList() {
                const postFeed = `https://pub-ff359827c45e40a7b6e9bad1878cd18a.r2.dev/feed/${this.postid}.json`;
                const categoryFeed = `https://pub-ff359827c45e40a7b6e9bad1878cd18a.r2.dev/feed/${this.category}.json`;

                const checkURLExists = async (url) => {
                    try {
                        const response = await fetch(url, { method: 'HEAD' });
                        return response.ok;
                    } catch {
                        return false;
                    }
                };

                const url = (await checkURLExists(postFeed)) ? postFeed : 
                            (await checkURLExists(categoryFeed)) ? categoryFeed : null;

                if (!url) {
                    console.error('Neither postFeed nor categoryFeed are available.');
                    return;
                }

                console.log('Using URL:', url);

                try {
                    const response = await fetch(url);
                    const data = await response.json();
                    console.log('Fetched data:', data);

                    const filteredList = data
                        .filter(item => item.url !== this.url)
                        .sort(() => Math.random() - 0.5)
                        .sort((a, b) => Number(b.exist) - Number(a.exist));

                    this.list.push(...filteredList);
                    console.log('Updated list:', this.list);

                    this.list.forEach((item, index) => {
                        if (item.exists) {
                            console.log('Item exists:', item, "Observing article:", index);
                            this.observeArticle(index);
                        }
                    });
                } catch (error) {
                    console.error('Error fetching data:', error);
                }
            },
            async getArticle(url, index) {
                if (!url) return;
                console.log('Fetching article content from:', url);

                try {
                    const response = await fetch(url);
                    const html = await response.text();
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const pages = doc.querySelectorAll('article.post.prose');
                    
                    let content = '';
                    pages.forEach(page => {
                        content += page.innerHTML;
                    });

                    if (this.list[index]) {
                        this.list[index].html = content || '';
                        console.log('Article HTML:', this.list[index].html);

                        if (this.list[index].html.length < 10) {
                            console.log('Content length:', this.list[index].html.length);
                        }
                    }
                } catch (error) {
                    console.error('Error fetching article:', error);
                }

                if (index === this.list.length - 1) {
                    this.page++;
                    this.loadList();
                }
            },
            async getContent(item) {
                console.log('Fetching content for:', item);

                const url = `https://us-east-1.aws.data.mongodb-api.com/app/azoio-evvkb/endpoint/create?id=${item._id}`;
                console.log('Content URL:', url);

                try {
                    const response = await fetch(url);
                    const data = await response.json();
                    const listItem = this.list.find(el => el._id === item._id);
                    
                    data.html = converter.makeHtml(data.content.replace(/#.*\n/, ''));
                    if (listItem) {
                        Object.assign(listItem, data);
                    }
                } catch (error) {
                    console.error('Error fetching content:', error);
                }
            },
            observeArticle(index) {
                this.$nextTick(() => {
                    const articleElement = document.getElementById(`article-${index}`);
                    if (!articleElement) return;

                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach(entry => {
                            if (entry.isIntersecting) {
                                console.log('Article in view:', index);
                                this.getContent(this.list[index]);
                                observer.unobserve(entry.target);
                            }
                        });
                    }, {
                        rootMargin: '0px 0px 200px 0px',
                        threshold: 0.1
                    });

                    observer.observe(articleElement);
                });
            },
            async expand(item) {
                item.html = "Loading...";
                const event = { label: 'expand', page: window.location.pathname };
                const obj = {
                    type: 'infinitygpt',
                    action: 1,
                    post_id: this.postid,
                    item: event
                };
                this.getContent(item);
                this.beaconTrack(obj);
            },
            beaconTrack(data) {
                const trackAPI = 'https://us-central1.gcp.data.mongodb-api.com/app/allwomenstalk-ebogu/endpoint/beacon';
                const beaconData = new Blob([JSON.stringify(data)], { type: 'application/json' });
                navigator.sendBeacon(trackAPI, beaconData);
            },
            subscribe: [""],
            cta: [""]
        };
    }
    </script>