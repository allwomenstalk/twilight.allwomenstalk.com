<div x-data="azo('',1)" @scroll.window.throttle="check({{loopNumber}})"  id="azo-{{loopNumber}}" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 px-4 max-w-screen-xl mx-auto">

<template x-for="item in list">
<div class="col-span-full rounded-md overflow-hidden"> 
  <a :href="item.url" class="_gptblocksarchives text-gray-900 rounded-lg hover:opacity-70 relative bg-teal-700">
    <div class="relative isolate overflow-hidden bg-pink-900">
      <div class="px-6 py-24 sm:px-6 sm:py-32 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl" x-text="item.title"></h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-gray-300" x-text="item.description"></p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            {# <a :href="item.ctaLink" class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-gray-900 shadow-sm hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" x-text="item.ctaText"></a> #}
            <a :href="item.url" class="text-sm font-semibold leading-6 text-white">Learn more <span aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>
      <svg viewBox="0 0 1024 1024" class="absolute left-1/2 top-1/2 -z-10 h-[64rem] w-[64rem] -translate-x-1/2 [mask-image:radial-gradient(closest-side,white,transparent)]" aria-hidden="true">
        <circle cx="512" cy="512" r="512" fill="url(#8d958450-c69f-4251-94bc-4e091a323369)" fill-opacity="0.7" />
        <defs>
          <radialGradient id="8d958450-c69f-4251-94bc-4e091a323369">
            <stop stop-color="#7775D6" />
            <stop offset="1" stop-color="#E935C1" />
          </radialGradient>
        </defs>
      </svg>
    </div>
  </a>
</div>
</template>

</div>
