{% set appName = app_name or "Allwomenstalk" %}
{% set appDownloadUrl = app_download_url or "https://apps.apple.com/app/apple-store/id525213890?pt=467793&ct=heroapp&mt=8" %}
{% set appLearnMoreUrl = app_learn_more_url or "https://allwomenstalk.com/" %}
{% set appIconUrl = app_icon_url or "https://allwomenstalk.com/images/appicon.png" %}
{% set appStoreBadgeUrl = appstore_badge_url or "https://allwomenstalk.com/images/appstore.svg" %}
{% set appHeadline = app_headline or "Don't Miss the Latest Version" %}
{% set appDescription = app_description or "Get the latest stories, save favorites, and share with friends — all in one place." %}
{% set appPrimaryCta = app_primary_cta or "Download" %}
{% set appSecondaryCta = app_secondary_cta or "Learn more" %}

<div class="hero mb-6 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="relative isolate overflow-hidden bg-transparent px-6 py-16 text-center sm:rounded-3xl sm:px-16">
      <img src="{{ appIconUrl }}" alt="{{ appName }} app icon" class="mx-auto h-16 w-16 rounded-2xl bg-white shadow-sm ring-1 ring-gray-900/10" width="64" height="64" loading="lazy" decoding="async" />
      <h2 class="mt-8 text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">{{ appHeadline }}</h2>
      <p class="mx-auto mt-6 max-w-xl text-pretty text-lg/8 text-gray-600">{{ appDescription }}</p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a href="{{ appDownloadUrl }}" class="inline-flex items-center justify-center rounded-md text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">
          <img src="{{ appStoreBadgeUrl }}" alt="Download on the App Store" class="h-10 w-auto" width="140" height="28" loading="lazy" decoding="async" />
          <span class="sr-only">{{ appPrimaryCta }}</span>
        </a>
        {# <a href="{{ appLearnMoreUrl }}" class="text-sm/6 font-semibold text-gray-900">{{ appSecondaryCta }} <span aria-hidden="true">→</span></a> #}
      </div>
    </div>
  </div>
</div>
