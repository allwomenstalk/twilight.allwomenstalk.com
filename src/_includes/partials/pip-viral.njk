<div
  id="aws-pip-viral"
  class="fixed bottom-3 right-3 z-50 w-44 overflow-hidden rounded-2xl border bg-slate-900 text-white transition duration-200 ease-out sm:w-56"
  style="position:fixed;right:12px;bottom:12px;z-index:2147483000;width:220px;max-width:42vw;aspect-ratio:16/10;overflow:hidden;border-radius:20px;border:1px solid rgba(255,255,255,.35);background:rgba(15,23,42,.95);color:#fff;box-shadow:0 20px 45px rgba(15,23,42,.35),0 8px 16px rgba(15,23,42,.25);transition:transform .22s ease,opacity .22s ease;"
  data-items='{{ pipItems | json | safe }}'
  data-cdn-base="{{ pip_viral_cdn_base | default('https://pub-ff359827c45e40a7b6e9bad1878cd18a.r2.dev') }}"
  data-cdn-paths='{{ pip_viral_cdn_paths | default(["quiz/pip.json", "poll/pip.json", "feed/pip.json"]) | json | safe }}'
  aria-live="polite">
  <a id="aws-pip-link" class="relative block h-full w-full text-white no-underline" href="#" target="_blank" rel="noopener noreferrer" aria-label="Open featured article">
    <img id="aws-pip-image" class="block h-full w-full object-cover object-center" src="" alt="Featured article image" loading="lazy" />
    <span class="absolute inset-0 bg-gradient-to-b from-transparent to-black/80" aria-hidden="true"></span>
    <span id="aws-pip-title" class="absolute bottom-2 left-2 right-2 block overflow-hidden text-left text-xs font-bold text-white sm:text-sm" style="max-height:3.75em;line-height:1.1;text-shadow:0 2px 8px rgba(2,6,23,.7);"></span>
  </a>
  <button id="aws-pip-close" class="absolute left-1.5 top-1.5 z-10 inline-flex h-5 w-5 items-center justify-center rounded-full border-0 bg-black/70 p-0 text-white hover:bg-black/90" style="position:absolute;left:6px;top:6px;z-index:10;width:20px;height:20px;border:0;border-radius:9999px;background:rgba(0,0,0,.7);padding:0;color:#fff;display:inline-flex;align-items:center;justify-content:center;" type="button" aria-label="Close picture in picture">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5 rotate-180" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.78 4.22a.75.75 0 0 1 0 1.06L7.06 8l2.72 2.72a.75.75 0 1 1-1.06 1.06L5.47 8.53a.75.75 0 0 1 0-1.06l3.25-3.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
    </svg>
  </button>
  <button id="aws-pip-expand" class="absolute left-0.5 top-1.5 z-20 hidden h-5 w-5 items-center justify-center border-0 bg-transparent p-0 text-white" style="position:absolute;left:2px;top:6px;z-index:20;width:20px;height:20px;align-items:center;justify-content:center;border:0;background:transparent;padding:0;color:#fff;" type="button" aria-label="Show picture in picture">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.78 4.22a.75.75 0 0 1 0 1.06L7.06 8l2.72 2.72a.75.75 0 1 1-1.06 1.06L5.47 8.53a.75.75 0 0 1 0-1.06l3.25-3.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
    </svg>
  </button>
</div>

<style>
  #aws-pip-viral.aws-pip-hidden {
    opacity: 0;
    transform: translateY(8px) scale(0.95);
    pointer-events: none;
  }

  #aws-pip-viral.aws-pip-collapsed {
    transform: translateX(calc(100% - 24px));
    background: rgba(15, 23, 42, 0.92);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.2);
  }

  #aws-pip-viral.aws-pip-collapsed #aws-pip-link,
  #aws-pip-viral.aws-pip-collapsed #aws-pip-close {
    display: none;
  }

  #aws-pip-viral.aws-pip-collapsed #aws-pip-expand {
    display: inline-flex;
  }

  .aws-pip-seq-image,
  .aws-pip-seq-word {
    opacity: 0;
    filter: blur(12px);
    transition: opacity 560ms cubic-bezier(0.19, 1, 0.22, 1), filter 560ms cubic-bezier(0.19, 1, 0.22, 1), transform 560ms cubic-bezier(0.19, 1, 0.22, 1);
    will-change: opacity, filter, transform;
  }

  .aws-pip-seq-image {
    transform: translate3d(0, 0.5rem, 0) scale(0.985);
  }

  .aws-pip-seq-word {
    display: inline-block;
    transform: translate3d(0, 0.3rem, 0);
  }

  .aws-pip-is-visible {
    opacity: 1;
    filter: blur(0);
    transform: translate3d(0, 0, 0) scale(1);
  }

  #aws-pip-viral.aws-pip-is-fading {
    opacity: 0.35;
    transition: opacity 420ms ease;
  }
</style>

<script>
  (function () {
    var root = document.getElementById("aws-pip-viral");
    if (!root || root.dataset.booted === "1") return;
    root.dataset.booted = "1";

    var link = document.getElementById("aws-pip-link");
    var image = document.getElementById("aws-pip-image");
    var title = document.getElementById("aws-pip-title");
    var closeBtn = document.getElementById("aws-pip-close");
    var expandBtn = document.getElementById("aws-pip-expand");
    var key = "aws-pip-viral-closed";
    var postIdMeta = document.querySelector('meta[name="postid"]');
    var postId = postIdMeta ? postIdMeta.getAttribute("content") : "";
    var lastImageByKey = {};
    var wordStepMs = 65;
    var durationVisibleMs = 3600;
    var fadeDurationMs = 420;
    var initialDelayMs = 2000;
    var cycleTimer = null;
    var animTimers = [];
    var currentItem = null;
    var lastClickTrackAt = 0;

    try {
      if (window.localStorage) {
        var saved = localStorage.getItem(key);
        if (saved === "1" || saved === "collapsed") {
          root.classList.add("aws-pip-collapsed");
        }
      }
    } catch (e) {}

    var items = [];
    var order = [];
    var idx = 0;
    try {
      items = JSON.parse(root.dataset.items || "[]");
    } catch (e) {
      items = [];
    }
    if (!Array.isArray(items)) items = [];

    function normalizeItem(item) {
      if (!item || typeof item !== "object") return null;
      var url = item.url || item.link || item.href || "";
      var title = item.title || item.quiz_title || item.question || item.headline || "";
      var slug = item.slug || item.id || url || "";
      var images = [];
      if (Array.isArray(item.images)) images = item.images.filter(Boolean);
      if (!images.length && item.image) images = [item.image];
      if (!images.length && item.image_url) images = [item.image_url];
      if (!title || !url || !images.length) return null;
      return {
        slug: slug,
        url: url,
        title: title,
        images: images
      };
    }

    function coerceItems(payload) {
      var rows = [];
      if (Array.isArray(payload)) rows = payload;
      else if (payload && Array.isArray(payload.items)) rows = payload.items;
      else if (payload && Array.isArray(payload.data)) rows = payload.data;
      else if (payload && Array.isArray(payload.feed)) rows = payload.feed;
      else if (payload && Array.isArray(payload.quiz)) rows = payload.quiz;
      else if (payload && Array.isArray(payload.poll)) rows = payload.poll;
      return rows.map(normalizeItem).filter(Boolean);
    }

    function shuffleItems(list) {
      var out = list.slice();
      for (var i = out.length - 1; i > 0; i -= 1) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = out[i];
        out[i] = out[j];
        out[j] = tmp;
      }
      return out;
    }

    function bootHiddenIfEmpty() {
      if (!items.length) {
        root.classList.add("aws-pip-hidden");
        return true;
      }
      return false;
    }

    function trackPipEvent(eventName, extraProps) {
      console.log('pip', eventName)
      var props = Object.assign({}, extraProps || {});
      try {
        var hasPosthog = window.posthog && typeof window.posthog.capture === "function";
        var baseProps = {
          component: "viral_pip",
          state: root.classList.contains("aws-pip-collapsed") ? "collapsed" : "open"
        };
        if (currentItem) {
          baseProps.item_slug = currentItem.slug || "";
          baseProps.item_title = currentItem.title || "";
          baseProps.item_url = currentItem.url || "";
        }
        props = Object.assign(baseProps, props);
        if (hasPosthog) window.posthog.capture(eventName, props);
      } catch (e) {}

      try {
        console.log('pip:',"trying sending pip click", eventName);
        if (eventName !== "aws_pip_click") return;
        console.log('pip:',"sending pip click");
        if (typeof beacontrack !== "function") return;
        var beaconPayload = {
          type: "pipviral",
          action: eventName,
          post_id: postId || "",
          item: {
            label: eventName,
            page: window.location.href,
            item_index: props.item_index,
            state: props.state || (root.classList.contains("aws-pip-collapsed") ? "collapsed" : "open"),
            item_slug: props.item_slug || (currentItem && currentItem.slug) || "",
            item_title: props.item_title || (currentItem && currentItem.title) || "",
            item_url: props.item_url || (currentItem && currentItem.url) || ""
          }
        };
        beacontrack(beaconPayload);
      } catch (e) {}
    }

    function pickRandomImage(item) {
      if (!item) return "";
      if (item.image) return item.image;
      if (Array.isArray(item.images) && item.images.length) {
        var list = item.images.filter(Boolean);
        if (!list.length) return "";
        var itemKey = item.slug || item.url || "default";
        var prev = lastImageByKey[itemKey] || "";
        var next = list[Math.floor(Math.random() * list.length)];
        if (list.length > 1 && next === prev) {
          next = list[(list.indexOf(next) + 1) % list.length];
        }
        lastImageByKey[itemKey] = next;
        return next;
      }
      return "";
    }

    function render(item) {
      if (!item) return;
      currentItem = item;
      link.href = item.url || "#";
      title.textContent = item.title || "Open article";
      image.src = pickRandomImage(item);
      image.alt = (item.title || "Featured article") + " image";
    }

    function pushTimer(id) {
      animTimers.push(id);
      return id;
    }

    function clearAnimTimers() {
      animTimers.forEach(function (id) { clearTimeout(id); });
      animTimers = [];
    }

    function clearSeqState() {
      root.classList.remove("aws-pip-is-fading");
      image.classList.remove("aws-pip-is-visible", "aws-pip-seq-image");
      title.querySelectorAll(".aws-pip-is-visible").forEach(function (el) {
        el.classList.remove("aws-pip-is-visible");
      });
      if (title.dataset.raw) title.textContent = title.dataset.raw;
    }

    function prepareWords(el) {
      var text = (el.textContent || "").replace(/\s+/g, " ").trim();
      el.dataset.raw = text;
      el.textContent = "";
      var words = text ? text.split(" ") : [];
      var frag = document.createDocumentFragment();
      words.forEach(function (word, i) {
        var span = document.createElement("span");
        span.className = "aws-pip-seq-word";
        span.textContent = word;
        frag.appendChild(span);
        if (i !== words.length - 1) frag.appendChild(document.createTextNode(" "));
      });
      el.appendChild(frag);
      return Array.prototype.slice.call(el.querySelectorAll(".aws-pip-seq-word"));
    }

    function animateIn() {
      if (root.classList.contains("aws-pip-collapsed")) return;
      image.classList.add("aws-pip-seq-image");
      var words = prepareWords(title);
      words.forEach(function (word, i) {
        pushTimer(setTimeout(function () {
          word.classList.add("aws-pip-is-visible");
        }, i * wordStepMs));
      });
      var titleDone = Math.max(0, words.length - 1) * wordStepMs + 560;
      pushTimer(setTimeout(function () {
        image.classList.add("aws-pip-is-visible");
      }, Math.min(titleDone + 120, 900)));
    }

    function animateOut() {
      root.classList.add("aws-pip-is-fading");
    }

    function scheduleNext() {
      if (cycleTimer) clearTimeout(cycleTimer);
      if (order.length < 2 || root.classList.contains("aws-pip-collapsed")) return;
      cycleTimer = setTimeout(function () {
        if (root.classList.contains("aws-pip-collapsed")) return;
        animateOut();
        pushTimer(setTimeout(function () {
          clearSeqState();
          idx = (idx + 1) % order.length;
          render(order[idx]);
          trackPipEvent("aws_pip_rotate", { item_index: idx });
          animateIn();
          scheduleNext();
        }, fadeDurationMs));
      }, durationVisibleMs);
    }

    function collapseWidget() {
      root.classList.add("aws-pip-collapsed");
      if (cycleTimer) clearTimeout(cycleTimer);
      cycleTimer = null;
      clearAnimTimers();
      clearSeqState();
    }

    function expandWidget() {
      root.classList.remove("aws-pip-collapsed");
      clearSeqState();
      animateIn();
      scheduleNext();
    }

    function applyItems(nextItems) {
      items = Array.isArray(nextItems) ? nextItems : [];
      if (bootHiddenIfEmpty()) return;
      order = shuffleItems(items);
      idx = 0;
      clearAnimTimers();
      clearSeqState();
      if (cycleTimer) clearTimeout(cycleTimer);
      cycleTimer = null;
      render(order[idx]);
      if (!root.classList.contains("aws-pip-collapsed")) {
        root.classList.add("aws-pip-hidden");
        pushTimer(setTimeout(function () {
          root.classList.remove("aws-pip-hidden");
          trackPipEvent("aws_pip_view", { item_index: idx });
          animateIn();
          scheduleNext();
        }, initialDelayMs));
      } else {
        root.classList.remove("aws-pip-hidden");
      }
    }

    function parseCdnPaths() {
      try {
        var parsed = JSON.parse(root.dataset.cdnPaths || "[]");
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        return [];
      }
    }

    function normalizeUrl(base, path) {
      if (!path) return "";
      if (/^https?:\/\//i.test(path)) return path;
      if (!base) return path;
      return base.replace(/\/+$/, "") + "/" + String(path).replace(/^\/+/, "");
    }

    function tryFetch(url) {
      return fetch(url, { cache: "no-store" })
        .then(function (res) {
          if (!res.ok) throw new Error("bad status " + res.status);
          return res.json();
        })
        .then(function (payload) {
          return coerceItems(payload);
        })
        .catch(function () {
          return [];
        });
    }

    function loadItemsFromCdn() {
      var base = root.dataset.cdnBase || "";
      var paths = parseCdnPaths();
      if (!paths.length) return Promise.resolve([]);
      var urls = paths.map(function (path) { return normalizeUrl(base, path); }).filter(Boolean);
      return urls.reduce(function (chain, url) {
        return chain.then(function (found) {
          if (Array.isArray(found) && found.length) return found;
          return tryFetch(url);
        });
      }, Promise.resolve([]));
    }

    applyItems(items.map(normalizeItem).filter(Boolean));

    loadItemsFromCdn().then(function (cdnItems) {
      if (!cdnItems.length) return;
      applyItems(cdnItems);
    });

    function trackPipClickOnce() {
      var now = Date.now();
      if (now - lastClickTrackAt < 500) return;
      lastClickTrackAt = now;
      trackPipEvent("aws_pip_click", { item_index: idx });
    }

    // Use capture + pointerdown so tracking runs before link navigation.
    link.addEventListener("pointerdown", trackPipClickOnce, true);
    link.addEventListener("click", trackPipClickOnce, true);

    closeBtn.addEventListener("click", function (ev) {
      ev.preventDefault();
      collapseWidget();
      trackPipEvent("aws_pip_collapse", { item_index: idx });
      try {
        if (window.localStorage) localStorage.setItem(key, "collapsed");
      } catch (e) {}
    });

    expandBtn.addEventListener("click", function (ev) {
      ev.preventDefault();
      expandWidget();
      trackPipEvent("aws_pip_expand", { item_index: idx });
      try {
        if (window.localStorage) localStorage.setItem(key, "open");
      } catch (e) {}
    });
  })();
</script>
