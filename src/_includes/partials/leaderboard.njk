{% if not post.noads %}
<div id="leaderboard" class="h-48 text-center overflow-hidden flex flex-wrap content-center bg-white" align="center" style="height:250px">
    <div id="HeaderAd" class=" mx-auto"></div>
</div>

<script async src="https://securepubads.g.doubleclick.net/tag/js/gpt.js"></script>
<script>
window.googletag = window.googletag || {cmd: []};
googletag.cmd.push(function() {
    // Declare slots initially present on the page
    var slot = googletag.defineSlot('/5445743/AWS-Universal', [[970,250],'fluid'], 'HeaderAd')
        .setTargeting('postID', '{{post.id}}')
        .setTargeting('category', '{{post.category}}')
        .setTargeting('position', 'HeaderAd')
        .setCollapseEmptyDiv(false)
        .addService(googletag.pubads());
    var mapping = googletag.sizeMapping()
        .addSize([980, 690], [[970, 250],[300,250]])
        .addSize([980, 480], [[970, 90],[728,90]])
        .addSize([0, 0], [[300, 250], [250,250]])
        .build();
    slot.defineSizeMapping(mapping);
    googletag.pubads().enableSingleRequest();
    googletag.pubads().setTargeting('category', ['apps']);
    googletag.enableServices();
    googletag.cmd.push(function() {
        googletag.display('HeaderAd');
    });
});
</script>
{% endif %}
