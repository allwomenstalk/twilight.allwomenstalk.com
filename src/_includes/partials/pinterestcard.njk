<script>

    function makepin(props) {
        return {
            postId: props.postId,
            mediaUrl: props.mediaUrl,
            postTitle: props.postTitle,
            postUrl: props.postUrl,
            pinurl: null, 
            init() {
                {# console.log('init pin'); #}
                this 
            },
            async pinit() {
                console.log('pinit');

                // Open a blank window immediately on user action to avoid popup blockers
                let newWindow = window.open('about:blank', '_blank');

                // Construct the trackapi URL with the passed-in parameters
                let trackapi = `https://us-central1.gcp.data.mongodb-api.com/app/allwomenstalk-ebogu/endpoint/track?type=pinterest&post_id=${encodeURIComponent(this.postId)}&post_title=${encodeURIComponent(this.postTitle)}&post_url=${encodeURIComponent(this.postUrl)}&post_image=${encodeURIComponent(this.mediaUrl)}`;
                console.log(trackapi);

                // Perform the tracking request
                await fetch(trackapi);
                // Assuming the fetch is for tracking and doesn't need a response processed here
                // Update the new window location after tracking succeeds
                if (newWindow) {
                    newWindow.location.href = 'https://www.pinterest.com/pin/create/button/?url=' + encodeURIComponent(this.pageUrl) + '&media=' + encodeURIComponent(this.mediaUrl) + '&description=' + encodeURIComponent(this.description);
