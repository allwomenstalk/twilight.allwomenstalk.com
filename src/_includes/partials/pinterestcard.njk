

{% set page_url = post.url %}
{% set media_url = 'https://pub-18d6387089a74708bbaea195784cb0ec.r2.dev/slide-'+post.id+'.png' %}
{% set description = post.title %}

<div x-data="makepin({
        postId: '{{ post.id }}',
        mediaUrl: '{{ media_url }}',
        postTitle: '{{ post.title | escape }}', // Escape to prevent breaking the JS with special characters
        postUrl: '{{ page_url | escape }}'
    })" class="max-w-md mx-auto grid overflow-hidden rounded-md ring-4 ring-red-600"> 
    <img class="mx-auto -mt-20 overflow-hidden" src="{{ media_url }}" alt="Image">
    <button @click="pinit()" 
        {# href="https://www.pinterest.com/pin/create/button/?url={{ page_url | urlencode }}&media={{ media_url | urlencode }}&description={{ description | urlencode }}" #}
        class="w-full rounded-b-md bg-red-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 flex items-center justify-center space-x-2">
        <svg class="w-8 text-white" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M11.935 2.375a9.625 9.625 0 0 0-3.507 18.563a9.102 9.102 0 0 1 0-2.75l1.135-4.813A3.472 3.472 0 0 1 9.3 12c0-1.334.777-2.338 1.74-2.338a1.21 1.21 0 0 1 1.217 1.375c0 .532-.218 1.236-.446 1.974c-.125.407-.254.825-.352 1.23a1.375 1.375 0 0 0 1.43 1.74c1.705 0 3.025-1.809 3.025-4.407a3.804 3.804 0 0 0-4.022-3.919a4.166 4.166 0 0 0-4.345 4.18a3.726 3.726 0 0 0 .688 2.193a.303.303 0 0 1 .068.275c-.075.303-.24.963-.268 1.093c-.027.13-.144.213-.323.13c-1.203-.563-1.952-2.316-1.952-3.732c0-3.032 2.207-5.823 6.36-5.823c3.333 0 5.932 2.378 5.932 5.562c0 3.313-2.062 5.98-4.998 5.98a2.586 2.586 0 0 1-2.207-1.1l-.598 2.29a10.69 10.69 0 0 1-1.196 2.523a9.74 9.74 0 0 0 2.88.399a9.625 9.625 0 0 0 0-19.25"/>
        </svg>
        <span>Pin it</span>
    </a>
</div>

<script>

    function makepin(props) {
        return {
            postId: props.postId,
            mediaUrl: props.mediaUrl,
            postTitle: props.postTitle,
            postUrl: props.postUrl,
            pinurl: null, 
            init() {
                {# console.log('init pin'); #}
                this 
            },
            async pinit() {
                console.log('pinit');

                // Open a blank window immediately on user action to avoid popup blockers
                let newWindow = window.open('about:blank', '_blank');

                // Construct the trackapi URL with the passed-in parameters
                let trackapi = `https://us-central1.gcp.data.mongodb-api.com/app/allwomenstalk-ebogu/endpoint/track?type=pinterest&post_id=${encodeURIComponent(this.postId)}&post_title=${encodeURIComponent(this.postTitle)}&post_url=${encodeURIComponent(this.postUrl)}&post_image=${encodeURIComponent(this.mediaUrl)}`;
                console.log(trackapi);

                // Perform the tracking request
                await fetch(trackapi);
                // Assuming the fetch is for tracking and doesn't need a response processed here
                // Update the new window location after tracking succeeds
                if (newWindow) {
                    newWindow.location.href = 'https://www.pinterest.com/pin/create/button/?url=' + encodeURIComponent(this.pageUrl) + '&media=' + encodeURIComponent(this.mediaUrl) + '&description=' + encodeURIComponent(this.description);
                } else {
                    console.error('Popup was blocked or closed by the user.');
                }
            }

        }
    }


document.addEventListener('DOMContentLoaded', function() {
    // Function to create and return a Pinterest "Pin It" button
    function createPinItButton(imageSrc, imageAlt, postId, postTitle, postUrl, mediaUrl) {
        const pinUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(postUrl)}&media=${encodeURIComponent(imageSrc)}&description=${encodeURIComponent(imageAlt)}`;
        const button = document.createElement('a');
        button.href = '#'; // Prevent default navigation
        button.innerText = 'Pin It';
        button.style.display = 'inline-block';
        button.style.width = '100%'; // Full width
        button.style.backgroundColor = '#e60023';
        button.style.color = 'white';
        button.style.textAlign = 'center';
        button.style.padding = '10px 0';
        button.style.margin = '10px 0'
        button.style.textDecoration = 'none';
        button.style.borderRadius = '5px';

        // Event listener for tracking and redirecting
        button.addEventListener('click', function(e) {
            e.preventDefault(); // Prevent default link behavior

            // Construct the tracking API URL
            let trackapi = `https://us-central1.gcp.data.mongodb-api.com/app/allwomenstalk-ebogu/endpoint/track?type=pinterest&post_id=${encodeURIComponent(postId)}&post_title=${encodeURIComponent(postTitle)}&post_url=${encodeURIComponent(postUrl)}&post_image=${encodeURIComponent(mediaUrl)}`;
            console.log(trackapi); // For debugging

            // Perform the tracking request
            fetch(trackapi)
                .then(response => {
                    if(response.ok) {
                        // If tracking succeeded, redirect to Pinterest
                        window.open(pinUrl, '_blank');
                    } else {
                        // Handle tracking failure (optional)
                        console.error('Tracking failed');
                    }
                })
                .catch(error => {
                    // Handle errors (e.g., network issues)
                    console.error('Error tracking the click:', error);
                });
        });

        return button;
    }

    // Example: Setting these values for demonstration. Replace with your actual data.
    const postId = '{{post.id}}'; // Your post ID
    const postTitle = '{{post.post_title}}'; // Your post title
    const postUrl = window.location.href; // Current URL as the post URL
    // Find all images inside .post divs
    const images = document.querySelectorAll('.post img');
    images.forEach(image => {
        const mediaUrl = image.src; // Assuming the image src as media URL for tracking
        const pinItButton = createPinItButton(image.src, image.alt || 'An interesting image', postId, postTitle, postUrl, mediaUrl);
        // Insert the Pin It button right after the image
        image.parentNode.insertBefore(pinItButton, image.nextSibling);
    });
});



</script>

