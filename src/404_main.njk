<main class="grid min-h-full place-items-center bg-white px-6 py-24 sm:py-32 lg:px-8">
  <div class="text-center">
    <p class="text-base font-semibold text-pink-600">404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-5xl">Page not found</h1>
    {# <p class="mt-6 text-base leading-7 text-gray-600">Sorry, we couldn’t find the page you’re looking for.</p> #}
    
    <div id="redirect-message" class="mt-6 text-base leading-7 text-gray-600"></div>

    <div class="mt-10 flex items-center justify-center gap-x-6">
      <a href="/" class="rounded-md bg-pink-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-pink-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-600">Go back home</a>
      <a href="https://allwomenstalk.com/contact.html" class="text-sm font-semibold text-gray-900">Contact support <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
</main>

    <script>
        // Get the current URL
        const currentUrl = window.location.href;

        // Extract the base URL (e.g., https://host.com/some-url) without the trailing path or query parameters
        const urlParts = currentUrl.split('/');
        console.log('parts',urlParts);
        const baseUrl = 'https://' + urlParts.slice(3, 5).join('/') + '/'
        console.log('base',baseUrl);

        // Construct the URL to check if it exists
        const checkUrl = `${baseUrl}`;
        console.log('check', checkUrl);

        // Check if the base URL exists
        fetch(checkUrl)
            .then(response => {
                console.log('response',response);
                if (response.ok) {
                    // If the base URL exists, redirect to it
                    window.location.href = baseUrl;
                    document.getElementById('redirect-message').innerHTML = `
                        <p>The page you are looking for does exist.</p>
                        <p>You will be redirected to the <a href="${baseUrl}">main page</a> in a few seconds.</p>
                    `;
                } else {
                    // If the base URL does not exist, display a message
                    document.getElementById('redirect-message').innerHTML = `
                        <p>The page you are looking for does not exist.</p>
                        <p>You can visit the <a href="${baseUrl}" class="underline">main page</a>.</p>
                    `;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('redirect-message').innerHTML = `
                    <p>There was an error checking the URL. Please try again later.</p>
                `;
            });
    </script>