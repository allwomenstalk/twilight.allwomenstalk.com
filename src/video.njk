---
layout: layout/default.njk
eleventyComputed:
  title: Video Posts - Allwomenstalk
  url: /{{metadata.host}}/video/
  permalink: /{{metadata.host}}/video/index.html

---

<div class="px-6 py-24 sm:py-32 lg:px-8">
    <div class="mx-auto max-w-xl text-center">
        <p class="text-base font-semibold leading-7 text-pink-600">Visual Stories</p>
        <h1 class="mt-6 text-4xl font-bold tracking-tight uppercase text-gray-900 sm:text-6xl">Video Posts</h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">Immersive content that brings stories to life with stunning visuals and
            engaging narratives.</p>
    </div>
</div>
<!-- Debug Info (remove in production) -->
{% if metadata.NODE_ENV != "production" %}
    <div class="max-w-screen-xl mx-auto px-4 py-4 bg-yellow-50 rounded-lg mb-8">
        <h3 class="text-sm font-medium text-yellow-800 mb-2">Debug Info:</h3>
        <p class="text-xs text-yellow-700">Total posts: {{ posts.length }}</p>
        <p class="text-xs text-yellow-700">Posts with video_url: {% set videoCount = 0 %}
            {% for post in posts %}
                {% if post.video_url %}
                    {% set videoCount = videoCount + 1 %}
                {% endif %}
            {% endfor %}
            {{ videoCount }}
        </p>
        {% if posts.length > 0 %}
            <p class="text-xs text-yellow-700">First post video_url: {{ posts[0].video_url or 'None' }}</p>
        {% endif %}
    </div>
{% endif %}
<div class="max-w-screen-2xl mx-auto px-4 py-8">
    {% for post in posts %}
        {% if post.video_url %}
            <div
                class="relative w-full h-96 mb-8 rounded-xl overflow-hidden group bg-gray-900">
                <!-- Background Image (always visible as fallback) -->
                <img
                src="{{ post.image }}" alt="{{ post.title }}" class="absolute inset-0 w-full h-full object-cover"/>
                <!-- Video Background (overlays image when loaded) -->
                <video class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000" autoplay loop muted playsinline preload="metadata" data-video-url="{{ post.video_url }}" onloadeddata="this.style.opacity='1'" onerror="console.error('Video failed:', this.dataset.videoUrl)">
                    <source src="{{ post.video_url }}" type="video/mp4"></video>
                    <!-- Dark Overlay -->
                    <div class="absolute inset-0 bg-black bg-opacity-40 group-hover:bg-opacity-30 transition-all duration-300"></div>
                    <!-- Content Overlay -->
                    <div class="absolute inset-0 flex items-center justify-center p-8">
                        <div
                            class="text-center text-white max-w-4xl">
                            <!-- Category Badge -->
                            <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-pink-600 text-white mb-4">
                                {{ post.category[0] | upper }}
                            </div>
                            <!-- Title -->
                            <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
                                {{ post.title }}
                            </h2>
                            <!-- Author and Date -->
                            <div class="flex items-center justify-center space-x-4 text-sm opacity-90 mb-6">
                                <span>By {{ post.author.name }}</span>
                                <span>•</span>
                                <span>{{ post.date | formatDate }}</span>
                                {% if post.comment_count > 0 %}
                                    <span>•</span>
                                    <span>{{ post.comment_count }} Comments</span>
                                {% endif %}
                            </div>
                            <!-- Read More Button -->
                            <a href="{{ post.url }}" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-pink-600 bg-white hover:bg-gray-50 transition-colors duration-200 group-hover:scale-105 transform transition-transform">
                                Read Full Article
                                <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                    <path
                                        fill-rule="evenodd"
                                        d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0
                                            110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                    <!-- Video Status Indicator -->
                    <div class="absolute top-4 right-4">
                        <div
                            class="w-12 h-12 bg-white bg-opacity-20 rounded-full flex items-center justify-center backdrop-blur-sm">
                            <!-- Loading spinner (shown by default) -->
                            <svg class="w-5 h-5 text-white animate-spin video-loading" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path
                                    class="opacity-75"
                                    fill="currentColor"
                                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <!-- Play icon (shown when video is ready) -->
                            <svg class="w-6 h-6 text-white ml-1 video-play hidden" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
                            </svg>
                            <!-- Error icon (shown when video fails) -->
                            <svg class="w-6 h-6 text-white video-error hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.268
                                        18.5c-.77.833.192 2.5 1.732 2.5z"/>
                            </svg>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    </div>
    <!-- No Video Posts Message -->
    {% set videoPostsCount = 0 %}
    {% for post in posts %}
        {% if post.video_url %}
            {% set videoPostsCount = videoPostsCount + 1 %}
        {% endif %}
    {% endfor %}
    {% if videoPostsCount == 0 %}
        <div class="max-w-screen-xl mx-auto px-4 py-16 text-center">
            <div class="bg-gray-50 rounded-lg p-12">
                <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2
                            2v8a2 2 0 002 2z"/>
                </svg>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No Video Posts Available</h3>
                <p class="text-gray-600">Check back later for new video content!</p>
            </div>
        </div>
    {% endif %}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const videos = document.querySelectorAll('video');
            console.log('Found videos:', videos.length);
            videos.forEach((video, index) => {
                const videoUrl = video.dataset.videoUrl;
                const container = video.closest('.group');
                const loadingIcon = container.querySelector('.video-loading');
                const playIcon = container.querySelector('.video-play');
                const errorIcon = container.querySelector('.video-error');
                console.log(`Video ${
                    index + 1
                } URL:`, videoUrl);
                video.addEventListener('loadeddata', function () {
                    console.log('Video loaded successfully:', videoUrl);
                    this.style.opacity = '1';
                    // Update icons
                    loadingIcon.classList.add('hidden');
                    playIcon.classList.remove('hidden');
                });
                video.addEventListener('loadstart', function () {
                    console.log('Video started loading:', videoUrl);
                });
                video.addEventListener('error', function (e) {
                    console.error('Video failed to load:', videoUrl, e);
                    // Update icons
                    loadingIcon.classList.add('hidden');
                    errorIcon.classList.remove('hidden');
                    // Keep image visible (video stays transparent)
                    this.style.opacity = '0';
                });
                video.addEventListener('canplay', function () {
                    console.log('Video can play:', videoUrl);
                    // Try to play the video
                    this.play().catch(e => {
                        console.log('Autoplay prevented for:', videoUrl, e);
                    });
                });
                // Timeout fallback - if video doesn't load in 10 seconds, show error
                setTimeout(() => {
                    if (video.style.opacity === '0' || video.style.opacity === '') {
                        console.log('Video timeout for:', videoUrl);
                        loadingIcon.classList.add('hidden');
                        errorIcon.classList.remove('hidden');
                    }
                }, 10000);
            });
        });
    </script>